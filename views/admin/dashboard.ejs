<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Combodeck Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
  <style>
    body {
      background-color: #f9f8f7;
      font-family: 'Poppins', sans-serif;
      color: #444;
      margin: 0;
      padding: 0;
    }

    /* Header */
    header {
      background: #fff;
      text-align: center;
      padding: 20px 0;
      font-size: 40px;
      font-weight: 500;
      color: #b6ada4;
      border-bottom: 1px solid #e6e3e1;
    }

    header i {
      position: absolute;
      right: 40px;
      top: 25px;
      font-size: 22px;
      color: #999;
      cursor: pointer;
    }

    /* Sidebar */
    .sidebar {
      width: 240px;
      height: calc(100vh - 80px);
      background: #fff;
      box-shadow: 0 0 10px rgba(0,0,0,0.05);
      position: fixed;
      top: 80px;
      left: 0;
      padding-top: 30px;
    }

    .sidebar a {
      display: flex;
      align-items: center;
      padding: 12px 20px;
      margin: 4px 10px;
      color: #555;
      border-radius: 10px;
      text-decoration: none;
      transition: 0.2s;
      font-size: 15px;
    }

    .sidebar a.active, .sidebar a:hover {
      background: #f0eeec;
      color: #000;
    }

    .sidebar a i {
      margin-right: 12px;
    }

    /* Main area */
    .main-content {
      margin-left: 260px;
      padding: 30px;
      margin-top: 20px;
    }

    .sales-cards .card {
      border: none;
      border-radius: 16px;
      padding: 15px;
      color: #444;
    }

    .sales-cards .card:nth-child(1){background:#ebe7e3;}
    .sales-cards .card:nth-child(2){background:#d8e0dc;}
    .sales-cards .card:nth-child(3){background:#dbe0d4;}
    .sales-cards .card:nth-child(4){background:#dbe3ed;}

    .progress-circle {
      width: 120px;
      height: 120px;
      border-radius: 50%;
      background: conic-gradient(#5b5b5b calc(var(--percent)*1%), #e9ecef 0);
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 20px auto;
    }

    .progress-circle span {
      background: #fff;
      border-radius: 50%;
      padding: 20px;
      font-weight: 600;
    }

    .chart-box {
      background: #fff;
      border-radius: 16px;
      padding: 20px;
      margin-top: 20px;
      box-shadow: 0 0 5px rgba(0,0,0,0.05);
    }

.left-panel {
  background: #f3f1ef;
  padding: 30px 20px !important;
  min-height: 1000px;
}
.left-panel .mb-4 {
  margin-bottom: 30px !important;
}
.summary-card {
  color: #fff;
  text-align: left;
}

.blue-card {
  background: #8fa2b7;
}

.green-card {
  background: #6f834c;
}

.analytics-box {
  background: #f4f4f4;
  
}

.list-box {
  background: #ffffff;
  padding: 28px !important;
}

.list-box h6 {
  font-size: 16px;
  font-weight: 600;
  margin-bottom: 22px;
  color: #444;
}

/* Row styling */
.top-list-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

/* Left side (index + name) */
.top-list-left {
  display: flex;
  align-items: center;
  gap: 14px;
}

/* Index number */
.top-index {
  font-size: 13px;
  color: #555;
  width: 18px;
}

/* Product / Category Name */
.top-name {
  font-size: 13px;
  letter-spacing: 0.4px;
  text-transform: uppercase;
  color: #333;
}

/* Sold count */
.top-count {
  font-size: 13px;
  color: #777;
}

/* Remove accidental collapse spacing */
#topProductsList,
#topCategoriesList {
  display: flex;
  flex-direction: column;
  gap: 6px;
}
  </style>
</head>
<body>
  <!-- Header -->
  <%- include('../partials/admin/headerSidebar') %>


  <!-- Main content -->
   <div class="main-content">
    <div class="container-fluid">
      <h3 class="mb-3 fw-bold">Dashboard</h3>
<div class="row">

  <!-- LEFT COLUMN -->
  <div class="col-md-4">
    <div class="left-panel p-4 rounded-5">

      <div class="mb-4 text-center">
        <p class="mt-3 fw-semibold">Top products distribution</p>
        <canvas id="productPie" style="height:280px"></canvas>
        
      </div>

      <div class="mb-4 text-center">
        <p class="mt-3 fw-semibold">Top categories distribution</p>
        <canvas id="categoryPie" style="height:280px;"></canvas>
        
      </div>

      <div class="text-center">
        <p class="mt-3 fw-semibold">Top fits distribution</p>
        <canvas id="subCategoryPie" style="height: 280px"></canvas>
        
      </div>

    </div>
  </div>

  <!-- RIGHT COLUMN -->
  <div class="col-md-8">

    <!-- SUMMARY CARDS -->
    <div class="row mb-4">

      <div class="col-md-4">
        <div class="summary-card blue-card p-4 rounded-4">
          <h5 class="mb-2 fw-bold" id="totalSales">Rs. 0</h5>
          <small>Total Sales</small>
        </div>
      </div>

      <div class="col-md-4">
        <div class="summary-card green-card p-4 rounded-4">
          <h5 class="mb-2 fw-bold" id="totalOrders">0</h5>
          <small>Total Orders</small>
        </div>
      </div>

      <div class="col-md-4">
        <div class="summary-card green-card p-4 rounded-4">
          <h5 class="mb-2 fw-bold" id="productsSold">0</h5>
          <small>Products Sold</small>
        </div>
      </div>

    </div>

    <!-- ANALYTICS -->
    <div class="analytics-box p-4 rounded-4">

      <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="fw-bold mb-0">Analytics</h5>

        <select id="filterSelect" class="form-select form-select-sm w-auto">
          <option value="daily">Daily</option>
          <option value="weekly">Weekly</option>
          <option value="monthly" selected>Monthly</option>
          <option value="yearly">Yearly</option>
          <option value="custom">Custom</option>
        </select>
      </div>

      <div id="customDateRange" class="d-none mb-3">
        <div class="d-flex gap-2">
          <input type="date" id="fromDate" class="form-control form-control-sm" />
          <input type="date" id="toDate" class="form-control form-control-sm" />
          <button id="applyCustomDate" class="btn btn-sm " style="background-color: #8fa2b7; color: #ffffff;">Apply</button>
        </div>
        <div id="dateError" class="text-danger small mt-1"></div>
      </div>

      <canvas id="salesLineChart"></canvas>

<div class="mt-4">

  <div class="list-box rounded-4 mb-4">
    <h6 class="fw-bold">Top products</h6>
    <div id="topProductsList"></div>
  </div>

  <div class="list-box rounded-4">
    <h6 class="fw-bold">Top categories</h6>
    <div id="topCategoriesList"></div>
  </div>

</div>

    </div>

  </div>

</div>
    </div>
  </div>

  <!-- footer -->
  <%- include('../partials/admin/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
  window.addEventListener('pageshow', function (event) {
    if (event.persisted) {
      window.location.reload();
    }
  });
</script>
<script>
let salesLineChart, productPie, categoryPie, subCategoryPie;

async function loadDashboard(filter="monthly", from=null, to=null) {

  let url = `/admin/dashboard-data?filter=${filter}`;

  if (filter === "custom") {
    url += `&from=${encodeURIComponent(from)}&to=${encodeURIComponent(to)}`;
  }

  const res = await fetch(url);
  const data = await res.json();

  if (!data.success) {
       const errorDiv = document.getElementById("dateError");
       if (errorDiv) {
         errorDiv.textContent = data.message;
       }
       return;
  }

// Update Summary Cards
if (data.summary) {
  document.getElementById("totalSales").innerText =
    "Rs. " + Number(data.summary.totalSales).toLocaleString("en-IN");

  document.getElementById("totalOrders").innerText =
    Number(data.summary.totalOrders);

  // Calculate total products sold
document.getElementById("productsSold").innerText =
  Number(data.summary.totalProductsSold || 0);
}

  const productLabels = data.products.map(p=>p.name);
  const productCounts = data.products.map(p=>p.count);

  const categoryLabels = data.categories.map(c=>c.name);
  const categoryCounts = data.categories.map(c=>c.count);
// ================= TOP 10 LIST RENDER =================

const productListDiv = document.getElementById("topProductsList");
const categoryListDiv = document.getElementById("topCategoriesList");

if (!Array.isArray(data.products) || !Array.isArray(data.categories)) {
  productListDiv.innerHTML = "<p class='text-danger'>Invalid product data</p>";
  categoryListDiv.innerHTML = "<p class='text-danger'>Invalid category data</p>";
} else {

productListDiv.innerHTML = data.products.map((item, index) => `
  <div class="top-list-row">
    <div class="top-list-left">
      <span class="top-index">${index + 1}</span>
      <span class="top-name">${item.name}</span>
    </div>
    <span class="top-count">${item.count} sold</span>
  </div>
`).join("");

categoryListDiv.innerHTML = data.categories.map((item, index) => `
  <div class="top-list-row">
    <div class="top-list-left">
      <span class="top-index">${index + 1}</span>
      <span class="top-name">${item.name}</span>
    </div>
    <span class="top-count">${item.count} sold</span>
  </div>
`).join("");
}
  const subCategoryLabels = data.subcategories.map(s=>s.name);
  const subCategoryCounts = data.subcategories.map(s=>s.count);


  if (salesLineChart) salesLineChart.destroy();
  if (productPie) productPie.destroy();
  if (categoryPie) categoryPie.destroy();
  if (subCategoryPie) subCategoryPie.destroy();



productPie = new Chart(document.getElementById('productPie'), {
  type: 'pie',
  data: {
    labels: productLabels,
    datasets: [{
      data: productCounts,
      backgroundColor: [
   
        '#B9BBBD',
        '#8C9BAF',
        '#6C7C91',
        '#8DA2BD',
        '#B2B18E',
        '#8B8A75',
        '#B3ABA4',
        '#9F9286',
        '#C4B4A5',
        '#ebe7e3'
      ],
      borderColor: '#ffffff',
      borderWidth: 1
    }]
  },
  options: {
    cutout: '30%',
    responsive: true,
    maintainAspectRatio: true,
plugins: {
legend: {
  position: 'bottom',
  align: 'start',
  fullSize: true,
  labels: {
    boxWidth: 10,
    padding: 10,
    usePointStyle: true,
    font: {
      size: 10
    }
  }
}
    }
  }
});

categoryPie = new Chart(document.getElementById('categoryPie'), {
  type: 'doughnut',
  data: {
    labels: categoryLabels,
    datasets: [{
      data: categoryCounts,
      backgroundColor: [
        '#dbe3ed',
        '#d8e0dc',
        '#ebe7e3',
        '#dbe0d4',
        '#cfd8dc',
        '#e6e3e1',
        '#e0f7fa',
        '#fce4ec',
        '#f9fbe7',
        '#ede7f6'
      ],
      borderColor: '#ffffff',
      borderWidth: 1
    }]
  },
  options: {
    cutout: '30%',
    responsive: true,
   maintainAspectRatio: true,
plugins: {
legend: {
  position: 'bottom',
  align: 'start',
  fullSize: true,
  labels: {
    boxWidth: 10,
    padding: 10,
    usePointStyle: true,
    font: {
      size: 10
    }
  }
}
    }
  }
});

subCategoryPie = new Chart(document.getElementById('subCategoryPie'), {
  type: 'doughnut',
  data: {
    labels: subCategoryLabels,
    datasets: [{
      data: subCategoryCounts,
      backgroundColor: [
        '#ebe7e3',
        '#d8e0dc',
        '#dbe3ed',
        '#dbe0d4',
        '#cfd8dc',
        '#e6e3e1',
        '#f1f8e9',
        '#e3f2fd',
        '#fce4ec',
        '#ede7f6'
      ],
      borderColor: '#ffffff',
      borderWidth: 1
    }]
  },
  options: {
    cutout: '30%',
    responsive: true,
    maintainAspectRatio: true,
    plugins: {
legend: {
  position: 'bottom',
  align: 'start',
  fullSize: true,
  labels: {
    boxWidth: 10,
    padding: 10,
    usePointStyle: true,
    font: {
      size: 10
    }
  }
}
    }
  }
});
// SALES LINE GRAPH
salesLineChart = new Chart(document.getElementById('salesLineChart'), {
  type: 'line',
  data: {
    labels: data.sales.labels,
    datasets: [{
      label: 'Sales (Rs)',
      data: data.sales.data,
      tension: 0.3,
      fill: true
    }]
  },
  options: {
    responsive: true,
    plugins: {
      legend: { display: true }
    },
    scales: {
      y: {
        beginAtZero: true
      }
    }
  }
});
}

const filterSelect = document.getElementById("filterSelect");
const customDiv = document.getElementById("customDateRange");

filterSelect.addEventListener("change", e => {

  const value = e.target.value;

  if (value === "custom") {
    customDiv.classList.remove("d-none");
  } else {
    customDiv.classList.add("d-none");
    loadDashboard(value);
  }
});

document.getElementById("applyCustomDate").addEventListener("click", () => {

  const errorDiv = document.getElementById("dateError");
  errorDiv.textContent = "";

  const from = document.getElementById("fromDate").value;
  const to = document.getElementById("toDate").value;

  if (!from || !to) {
    errorDiv.textContent = "Please select both start and end dates";
    return;
  }

  if (new Date(from) > new Date(to)) {
    errorDiv.textContent = "Start date cannot be greater than end date";
    return;
  }

const todayDate = new Date();
todayDate.setHours(23,59,59,999);

if (new Date(from) > todayDate || new Date(to) > todayDate) {
  errorDiv.textContent = "Future dates are not allowed";
  return;
}

  loadDashboard("custom", from, to);
});

loadDashboard();
</script>
</body>
</html>
