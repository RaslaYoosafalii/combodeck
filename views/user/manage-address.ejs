<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Manage Address</title>

  <style>
    * {
      box-sizing: border-box;
      font-family: "Arial", sans-serif;
    }

body {
  margin: 0;
  background: #0a0e11;
  color: white;
}

    /* ===== LAYOUT ===== */
    .profile-wrapper {
      display: flex;
      padding: 40px 60px;
      margin-top: 110px;
      gap: 40px;
       align-items: flex-start; 
    }


    /* ===== ADDRESS CARD ===== */
    .profile-card {
     flex: 1;
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 16px;
  padding: 40px;
  box-shadow: 0 10px 30px rgba(0,0,0,0.35);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  position: relative;
    }

    .profile-title {
      text-align: center;
      font-size: 28px;
      letter-spacing: 2px;
      margin-bottom: 40px;
    }

.add-address-btn {
  position: absolute;
  top: 40px;
  right: 40px;
  background: rgba(255,255,255,0.04);
  color: white;
  border: 1px solid rgba(255,255,255,0.08);
  padding: 10px 16px;
  border-radius: 6px;
  font-size: 13px;
  cursor: pointer;
}

    /* ===== ADDRESS LIST ===== */
.address-card {
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.08);
  padding: 20px;
  border-radius: 12px;
  margin-bottom: 20px;
  position: relative;
}

    .address-name {
      font-weight: 700;
      margin-bottom: 6px;
    }

.address-text {
  font-size: 14px;
  color: rgba(255,255,255,0.7);
  line-height: 1.6;
}

    .address-actions {
      position: absolute;
      top: 20px;
      right: 20px;
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

.address-actions button {
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.08);
  color: white;
  padding: 4px 10px;
  font-size: 12px;
  border-radius: 6px;
  cursor: pointer;
}

    .address-type {
      position: absolute;
      bottom: 14px;
      right: 20px;
      background: #e0e0e0;
      font-size: 12px;
      padding: 4px 10px;
      border-radius: 6px;
      color: #444;
    }
.address-type-btn {
 background: rgba(255,255,255,0.06);
 border: 1px solid rgba(255,255,255,0.08);
 font-size: 12px;
 padding: 3px 10px;
 border-radius: 6px;
 margin-left: 10px;
 color: white;
 font-weight: 500;
}
     .address-actions button:last-child {
     background: red;
     border-color: red;
     color: #fff;
    }



  </style>
</head>

<body>
  <%- include('../partials/user/loggedinHeader') %>

  <div class="profile-wrapper">

    <!-- ===== SIDEBAR ===== -->
  <%- include('../partials/user/profileSidebar') %>

    <!-- ===== ADDRESS CONTENT ===== -->
    <section class="profile-card">
      <h2 class="profile-title">MANAGE ADDRESS</h2>

      <button class="add-address-btn" onclick="location.href='/address/add'">
        Add new Address
      </button>

      <% if (addresses && addresses.length > 0) { %>
        <% addresses.forEach((addr, index) => { %>
  <div class="address-card">


  <div class="address-name">
    <%= addr.name %>
    <span class="address-type-btn"><%= addr.addressType %></span>

      <% if (addr.isDefault) { %>
        <span class="address-type-btn" style="background:#434343;color:#fff;">
         Default
       </span>
      <% } %>
  </div>

  <div class="address-text">
    <%= addr.mobileNumber %>
  </div>

  <div class="address-text">
    <%= addr.address %>, <%= addr.locality %>, <%= addr.city %>, <%= addr.state %> - <%= addr.pincode %>
  </div>

  <% if (addr.landmark) { %>
    <div class="address-text">
      Landmark - <%= addr.landmark %>
    </div>
  <% } %>

<% if (addr.alternativeNumber) { %>
  <div class="address-text">
    Alt number - <%= addr.alternativeNumber %>
  </div>
<% } %>

  <div class="address-actions">
    <% if (!addr.isDefault) { %>
<button onclick="setDefaultAddress('<%= index %>')" style="background: rgba(255,255,255,0.08); color: white; border: 1px solid rgba(255,255,255,0.08);">    Set Default
  </button>
<% } %>
    <button onclick="location.href='/address/edit/<%= index %>'">Edit</button>
    <button onclick="deleteAddress('<%= index %>')">Delete</button>
  </div>

</div>
        <% }) %>
      <% } else { %>
        <p style="text-align:center;color:rgba(255,255,255,0.6);">No addresses found</p>
      <% } %>
    </section>
  </div>

  <%- include('../partials/user/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <script>
    function deleteAddress(index) {
      Swal.fire({
        title: 'Delete address?',
        text: 'This address will be permanently removed',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#d33',
        cancelButtonColor: '#aaa',
        confirmButtonText: 'Yes, delete'
      }).then((result) => {
        if (result.isConfirmed) {
          fetch(`/address/delete/${index}`, {
            method: 'DELETE'
          }).then(res => res.json())
             .then(data => {
               if (data.success && data.type === 'deleted') {
                 Swal.fire('Deleted!', 'Address deleted successfully', 'success')
             .then(() => {
  window.location.href = '/address';
});

            }
          })
        }
      });
    }
  </script>
  <script>
  const params = new URLSearchParams(window.location.search);

  if (params.get('success') === 'added') {
    Swal.fire('Success', 'Address added successfully', 'success');
  }

if (params.get('success') === 'updated') {
  Swal.fire('Success', 'Address updated successfully', 'success')
    .then(() => {
      window.history.replaceState({}, document.title, '/address');
    });
}

  if (params.get('error') === 'saveFailed') {
  Swal.fire('Error', 'Failed to save address. Try again.', 'error');
}


</script>
<script>
function setDefaultAddress(index) {
  fetch(`/address/set-default/${index}`, {
    method: 'POST'
  })
  .then(res => res.json())
  .then(data => {
    if (data.success) {
      Swal.fire('Updated', 'Default address updated', 'success')
        .then(() => location.reload());
    } else {
      Swal.fire('Error', 'Unable to set default address', 'error');
    }
  });
}
</script>


</body>
</html>
