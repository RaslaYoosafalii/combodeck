<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Combodeck Login</title>
  <style>
    /* Reset */
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-family: "Poppins", sans-serif;
}

body {
  min-height: 100vh;
  background: #0a0e11;
  color: white;
  display: flex;
  flex-direction: column;
}

.wrapper {
  margin: auto;
  margin-top:110px;
  width: 400px;
  text-align: center;
  padding: 35px;
  border-radius: 16px;
  background: rgba(255,255,255,0.03);
  backdrop-filter: blur(10px);
  box-shadow: 0 10px 30px rgba(0,0,0,0.35);
}

/* Google login button */
.google-btn {
  font-size: 14px;
  font-weight: 500;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  margin-bottom: 20px;
  width: 100%;
  padding: 12px;
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 8px;
  background: rgba(255,255,255,0.04);
  color: white;
}

.google-btn img {
  width: 18px;
  height: 18px;
  border-radius: 50%;
  background: rgba(255,255,255,0.08);
}
.google-btn:hover{
  background-color: #d0a65c42;
}

/* Divider */
.divider {
  display: flex;
  align-items: center;
  text-align: center;
  margin: 15px 0;
  color: rgba(255,255,255,0.6);
  font-size: 14px;
}

.divider::before,
.divider::after {
  content: "";
  flex: 1;
  height: 1px;
  background: rgba(255,255,255,0.08);
  margin: 0 10px;
}

/* Brand */
.brand {
  font-size: 26px;
  color: rgba(255, 255, 255, 0.79);
  margin: 15px 0 25px;
  font-weight: bold;
}

/* Input fields */
form input {
  width: 100%;
  padding: 12px;
  margin: 8px 0;
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 8px;
  font-size: 14px;
  background: rgba(255,255,255,0.04);
  color: white;
}

/* Password with toggle */
.password-wrapper {
  position: relative;
}

.toggle-password {
  position: absolute;
  right: 12px;
  top: 50%;
  transform: translateY(-50%);
  cursor: pointer;
  color: rgba(255,255,255,0.65);
  display: flex;
  align-items: center;
  transition: 0.3s;
}

.toggle-password:hover {
  color: white;
}
/* Forgot password */
.forgot {
  display: block;
  text-align: right;
  font-size: 13px;
  margin: 5px 0 15px;
  color: #ffffffb8;
  text-decoration: none;
}

.forgot:hover {
  text-decoration: underline;
}

/* Login button */
.login-btn {
  font-size: 15px;
  font-weight: 600;
  cursor: pointer;
  transition: background 0.3s;
  width: 100%;
  padding: 12px;
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 8px;
  background: rgba(255,255,255,0.04);
  color: white;
}

.login-btn:hover {
  background-color: #d0a65c42;
}
/* Signup text */
.signup-text {
  margin-top: 20px;
  font-size: 14px;
   color: rgba(255,255,255,0.7);
}

.signup-text a {
  color: #d0a55c;
  font-weight: 600;
  text-decoration: none;
}

.signup-text a:hover {
  text-decoration: underline;
}

  </style>
</head>
<body>

  <%- include('../partials/user/header') %>
  <div class="wrapper">

    <!-- Google login button -->
    <button class="google-btn" onclick="window.location.href='/auth/google'">
      <img src="https://developers.google.com/identity/images/g-logo.png" alt="Google Logo">
      Login with Google
    </button>

    <div class="divider"><span>or</span></div>

    <!-- Brand / Logo -->
    <h1 class="brand">Login</h1>
<% if (typeof message !== 'undefined' && message) { %>
  <p style="color: rgb(122, 23, 23); margin-bottom: 2px; font-size: small;"><%= message %></p>
<% } %>


    <!-- Login form -->
    <form action="/login" method="POST" >
      <input type="email" name="email" placeholder="Email Address" required novalidate>

      <div class="password-wrapper">
        <input type="password" name="password" id="password" placeholder="Password"  required novalidate>
<span class="toggle-password" onclick="togglePassword()">
  <svg id="eyeIcon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
    <path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7S1 12 1 12z"/>
    <circle cx="12" cy="12" r="3"/>
  </svg>
</span>      </div>

      <a href="/forgot-password" class="forgot">Forget Password?</a>

      <button type="submit" class="login-btn">Login</button>
    </form>

    <p class="signup-text">
      NEW USER? <a href="/signup">Sign up</a>
    </p>
  </div>

  <script>
function togglePassword() {
  const pwd = document.getElementById("password");
  const eyeIcon = document.getElementById("eyeIcon");

  if (pwd.type === "password") {
    pwd.type = "text";
    eyeIcon.innerHTML = `
      <path d="M17.94 17.94A10.94 10.94 0 0 1 12 19C5 19 1 12 1 12a21.77 21.77 0 0 1 5.06-5.94"/>
      <path d="M9.9 4.24A10.94 10.94 0 0 1 12 5c7 0 11 7 11 7a21.8 21.8 0 0 1-3.22 4.31"/>
      <path d="M1 1l22 22"/>
    `;
  } else {
    pwd.type = "password";
    eyeIcon.innerHTML = `
      <path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7S1 12 1 12z"/>
      <circle cx="12" cy="12" r="3"/>
    `;
  }
}
  </script>
 <%- include('../partials/user/footer') %> 
</body>

</html>

