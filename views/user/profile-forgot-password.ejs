<!DOCTYPE html>
<html>
<head>
  <title>Verify Email</title>
  
  <style>
    body{ 
  font-family: 'Arial', sans-serif;
  padding:0;
  margin:0;
  background:#fff;
}
    .card{height: 250px;max-width:420px;margin-top: 300px;margin:80px auto;align-items: center;background:#fff;padding:40px;border-radius:15px;box-shadow:0 10px 30px rgba(0,0,0,.15)}
    input,button{width:100%;padding:12px;margin-top:15px; border-radius: 5px; border: 0.5px solid ;}
    button{background:#4a4745;color:#fff;border:none;border-radius:5px}
  </style>
  
</head>
<body>
  <%-include('../partials/user/loggedinHeader')%>
<div style="display:flex;justify-content:center;align-items:center;padding:60px 20px; font-family: Georgia, 'Times New Roman', Times, serif;">
  <div class="card" style="align-items: center;">
  <h2 style="text-align:center">Verify Your Email</h2>

  <form method="POST" action="/profile/forgot-password">
    <p style="text-align:center; font-family: Georgia, 'Times New Roman', Times, serif; ">Please enter your registered email to change password</p>
    <input type="email" name="email" placeholder=" Enter registered email" style=" width: 330px; margin-left: 30px; margin-right: 30px"  required />
    <button type="submit" style=" width: 357px; margin-left: 30px; margin-right: 30px">Send OTP</button>
  </form>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<% if (typeof message !== 'undefined' && message) { %>
<script>
  Swal.fire({
    icon:'error',
    text:"<%= message %>",
    confirmButtonColor:'#4a4745'
  })
</script>
<% } %>

</body>
</html>
