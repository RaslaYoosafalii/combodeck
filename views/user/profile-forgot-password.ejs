<!DOCTYPE html>
<html>
<head>
  <title>Verify Email</title>
  
<style>
  * {
    box-sizing: border-box;
    font-family: Arial, sans-serif;
  }

  body {
    margin: 0;
    padding: 0;
    background: #0a0e11;
    color: white;
  }

  .forgot-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: calc(100vh - 120px);
    padding: 60px 20px;
  }

  .card {
    width: 100%;
    max-width: 460px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.35);
    padding: 45px 40px;
  }

  .card h2 {
    text-align: center;
    margin-bottom: 16px;
    font-size: 28px;
    letter-spacing: 1px;
    color: white;
  }

  .card p {
    text-align: center;
    color: rgba(255,255,255,0.75);
    margin-bottom: 25px;
    line-height: 1.6;
    font-size: 14px;
  }

  input,
  button {
    width: 100%;
    padding: 14px 16px;
    margin-top: 16px;
    border-radius: 8px;
    font-size: 14px;
  }
  button:hover{
   background: rgba(168, 118, 43, 0.2);
  color: white;
  border-color:  rgba(220, 173, 102, 0.2);
  }
  input {
    border: 1px solid rgba(255,255,255,0.08);
    background: rgba(255,255,255,0.04);
    color: white;
    outline: none;
  }

  input::placeholder {
    color: rgba(255,255,255,0.45);
  }

  input:focus {
    border-color: rgba(255,255,255,0.18);
    background: rgba(255,255,255,0.06);
  }

  button {
    background: rgba(255,255,255,0.04);
    color: white;
    border: 1px solid rgba(255,255,255,0.08);
    cursor: pointer;
    transition: 0.3s ease;
  }

  button:hover {
    background: rgba(255,255,255,0.08);
    transform: translateY(-1px);
  }
  .forgot-main {
  width: 100%;
  max-width: 460px;
}

.breadcrumbs {
  margin-bottom: 18px;
  font-size: 14px;
  color: rgba(255,255,255,0.65);
  display: flex;
  align-items: center;
  gap: 10px;
}

.breadcrumbs a {
  color: rgba(255,255,255,0.75);
  text-decoration: none;
  transition: 0.3s;
}

.breadcrumbs a:hover {
  color: white;
}
</style>
  
</head>
<body>
  <%-include('../partials/user/loggedinHeader')%>
<div class="forgot-wrapper">
  <div class="forgot-main">
    <div class="breadcrumbs" id="breadcrumbs">
      <a href="/profile">Profile</a>
      <span>›</span>
      <span>Verify Email</span>
    </div>

    <div class="card">
  <h2 style="text-align:center">Verify Your Email</h2>

  <form method="POST" action="/profile/forgot-password">
    <p>Please enter your registered email to change password</p>
<input type="email" name="email" placeholder="Enter registered email" required />
    <button type="submit">Send OTP</button>
  </form>
</div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<% if (typeof message !== 'undefined' && message) { %>
<script>
  Swal.fire({
    icon:'error',
    text:"<%= message %>",
    confirmButtonColor:'#4a4745'
  })
</script>
<% } %>
<script>
  document.addEventListener("DOMContentLoaded", function () {
    const breadcrumb = document.getElementById("breadcrumbs");
    const referrer = document.referrer;

    if (referrer.includes("/profile/change-password")) {
      breadcrumb.innerHTML = `
        <a href="/profile">Profile</a>
        <span>›</span>
        <a href="/profile/change-password">Change Password</a>
        <span>›</span>
        <span>Verify Email</span>
      `;
    } else {
      breadcrumb.innerHTML = `
        <a href="/profile">Profile</a>
        <span>›</span>
        <span>Verify Email</span>
      `;
    }
  });
</script>
  <%- include('../partials/user/footer') %>
</body>
</html>
