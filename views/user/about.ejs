    <style>
      :root{
    --gold: rgb(220,173,102);
    --bg: #0a0e11;
    --glass: rgba(255,255,255,.04);
    --border: rgba(255,255,255,.08);
}

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    font-family:'Inter',sans-serif;
    background:
    radial-gradient(
      circle at top right,
      rgba(220,173,102,.04),
      transparent 40%
    ),
    #0a0e11;

    color:white;
    overflow-x:hidden;
}

.container{
    width:min(1400px,92%);
    margin:auto;
}

.glass{
    background:rgba(255,255,255,.04);

    border:1px solid rgba(255,255,255,.08);

