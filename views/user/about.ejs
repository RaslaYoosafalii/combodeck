<script>

const image =
document.getElementById('facilityImage');

const cards =
document.querySelectorAll('.facility-card');

let current = 0;
let sliderInterval;

const facilityData = [

{
    image:'/images/factory1.png'
},

{
    image:'/images/factory2.png'
},

{
    image:'/images/factory3.png'
},

{
    image:'/images/factory4.png'
}

];

function showSlide(index){

    current = index;

    image.style.opacity = 0;

    setTimeout(()=>{

        image.src =
        facilityData[index].image;

        image.style.opacity = 1;

    },250);

    cards.forEach(card=>{
        card.classList.remove('active');
    });

    cards[index].classList.add('active');
}

function startAutoSlide(){

    sliderInterval = setInterval(()=>{

        current++;

        if(current >= facilityData.length){

            current = 0;
        }

        showSlide(current);

    },5000);

}

cards.forEach(card=>{

    card.addEventListener('click',()=>{

        clearInterval(sliderInterval);

        const index =
        Number(card.dataset.index);

        showSlide(index);

        startAutoSlide();

    });

});

showSlide(0);

startAutoSlide();

</script>
<script>

const mailStatus = "<%= mail %>";

if(mailStatus === 'missing'){
  Swal.fire({
    icon:'warning',
    title:'Missing Fields',
    text:'Please fill all required fields.'
  });
}

if(mailStatus === 'invalid-email'){
  Swal.fire({
    icon:'warning',
    title:'Invalid Email',
    text:'Please enter a valid email address.'
  });
}

if(mailStatus === 'invalid-name'){
  Swal.fire({
    icon:'warning',
    title:'Invalid Name',
    text:'Name must contain at least 2 characters.'
  });
}

if(mailStatus === 'invalid-subject'){
  Swal.fire({
    icon:'warning',
    title:'Invalid Subject',
    text:'Subject must contain at least 3 characters.'
  });
}

if(mailStatus === 'short-message'){
  Swal.fire({
    icon:'warning',
    title:'Message Too Short',
    text:'Please provide more details in your message.'
  });
}

if(mailStatus){

    window.history.replaceState(
        {},
        document.title,
        window.location.pathname
    );

}

if(mailStatus === 'success'){

    Swal.fire({

        icon:'success',

        title:'Message Sent',

        text:'Thank you for contacting us. Our team will get back to you shortly.',

        confirmButtonText:'Great',

        background:'rgba(15,18,22,.95)',

        color:'#ffffff',

        backdrop:`
            rgba(0,0,0,.75)
        `,

        customClass:{
            popup:'glass-alert',
            confirmButton:'gold-btn'
        }

    }).then(()=>{

        window.history.replaceState(
            {},
            document.title,
            window.location.pathname
        );

    });

}



if(mailStatus === 'failed'){

    Swal.fire({

        icon:'error',

        title:'Something Went Wrong',

        text:'Unable to send your message. Please try again later.',

        confirmButtonText:'Okay',

        background:'rgba(15,18,22,.95)',

        color:'#ffffff',

        backdrop:`
            rgba(0,0,0,.75)
        `,

        customClass:{
            popup:'glass-alert',
            confirmButton:'gold-btn'
        }

    });

}

</script>

