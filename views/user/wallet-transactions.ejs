<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Wallet Transactions</title>

<style>
* {
  box-sizing: border-box;
  font-family: "Arial", sans-serif;
}

body {
  margin: 0;
  background: #0a0e11;
  color: white;
}

/* ===== LAYOUT ===== */
.profile-wrapper {
  display: flex;
  padding: 40px 60px;
  margin-top: 110px;
  gap: 40px;
  align-items: flex-start;
}

/* ===== MAIN CARD ===== */
.profile-card {
  flex: 1;
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 16px;
  padding: 40px;
  box-shadow: 0 10px 30px rgba(0,0,0,0.35);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  position: relative;
  min-height: 615.5px;
}

/* ===== TITLE ===== */
.profile-title {
  text-align: center;
  font-size: 28px;
  letter-spacing: 2px;
  margin-bottom: 40px;
}

/* ===== BACK BUTTON ===== */
.back-btn {
  position: absolute;
  top: 40px;
  right: 40px;
  background: rgba(255,255,255,0.04);
  color: white;
  border: 1px solid rgba(255,255,255,0.08);
  padding: 10px 16px;
  border-radius: 6px;
  font-size: 13px;
  cursor: pointer;
}

.transaction-header {
  display: flex;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.08);
  padding: 14px 28px;
  border-radius: 8px;
  font-weight: 600;
  margin-bottom: 15px;
}

.transaction-row {
  display: flex;
  padding: 14px 28px;
  border-bottom: 1px solid rgba(255,255,255,0.08);
  font-size: 14px;
}

.transaction-header span:nth-child(2),
.transaction-row span:nth-child(2) {
  flex: 0.4;   /* middle column wider */
}

.transaction-row:last-child {
  border-bottom: none;
}

.transaction-header span,
.transaction-row span {
  flex: 1;
  text-align: left;
  
}

.transaction-header span:last-child,
.transaction-row span:last-child {
  text-align: right;
  flex: 1; 
}



/* ===== PAGINATION ===== */
.pagination {
  margin-top: 30px;
  text-align: center;
}

.page-btn {
  display: inline-block;
  margin: 0 5px;
  padding: 8px 14px;
  background: rgba(255,255,255,0.04);
  color: white;
  text-decoration: none;
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 6px;
  font-size: 14px;
}
.page-btn:hover {
  background: rgba(255,255,255,0.08);
}

.page-btn.active {
  background: rgba(255,255,255,0.12);
  color: white;
}
</style>
</head>

<body>

<%- include('../partials/user/loggedinHeader') %>

<div class="profile-wrapper">

  <%- include('../partials/user/profileSidebar') %>

  <section class="profile-card">
    <h2 class="profile-title">TRANSACTION HISTORY</h2>

    <button onclick="location.href='/wallet'" class="back-btn">
      ← Back
    </button>

    <% if (wallet && wallet.transactions && wallet.transactions.length > 0) { %>

      <div class="transaction-header">
        <span>Date</span>
        <span>Transaction</span>
        <span>Amount</span>
      </div>

     <% transactions.forEach(t => { %>
        <div class="transaction-row">
          <span><%= new Date(t.createdAt).toLocaleString() %></span>
          <span><%= t.description %></span>
          <span style="color:<%= t.type==='credit' ? '#97cc7a' : '#cf4846' %>; text-shadow: 0 0 8px rgba(255,255,255,0.08)">
            <%= t.type==='credit'?'+':'-' %>Rs. <%= t.amount %>
          </span>
        </div>
      <% }) %>

    <% } else { %>
      <p style="text-align:center;color:rgba(255,255,255,0.6);">No transactions found</p>
    <% } %>

  <% if (totalPages > 1) { %>
  <div class="pagination">

    <% if (currentPage > 1) { %>
      <a href="/wallet/history?page=<%= currentPage - 1 %>" class="page-btn">
        &lt;
      </a>
    <% } %>

    <% for (let i = 1; i <= totalPages; i++) { %>
      <a href="/wallet/history?page=<%= i %>" 
         class="page-btn <%= i === currentPage ? 'active' : '' %>">
        <%= i %>
      </a>
    <% } %>

    <% if (currentPage < totalPages) { %>
      <a href="/wallet/history?page=<%= currentPage + 1 %>" class="page-btn">
        &gt;
      </a>
    <% } %>

  </div>
<% } %>
  </section>

</div>

<%- include('../partials/user/footer') %>

</body>
</html>
