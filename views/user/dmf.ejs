<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>DMF Technology</title>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

<style>
:root{
  --bg:#050505;
  --panel:rgba(20,20,20,.55);
  --yellow:rgb(208, 162, 93);;
  --white:#F5F5F5;
  --muted:#B8B8B8;
  --border:rgba(255,212,0,.15);
}

*{margin:0;padding:0;box-sizing:border-box}
body{
  font-family:'Inter',sans-serif;
  background:var(--bg);
  color:var(--white);
  overflow-x:hidden;

background:
radial-gradient(
circle at top right,
rgba(220,173,102,.04),
transparent 40%
),
#0a0e11;
}

body::before{
  content:'';
  position:fixed;
  inset:0;
  background:
  radial-gradient(circle at 20% 20%, rgba(63, 62, 58, 0.08), transparent 35%),
  radial-gradient(circle at 80% 40%, rgba(18, 18, 17, 0.05), transparent 30%);
  pointer-events:none;
}

.container{
  width:min(1400px,92%);
  margin:auto;
}

.glass{
  background:var(--panel);
  backdrop-filter:blur(24px);
  border:1px solid var(--border);
  border:1px solid rgba(255,255,255,0.1);
  border-radius:24px;
  box-shadow:
  inset 0 1px 0 rgba(255,255,255,.05),
  0 0 40px rgba(255,212,0,.05);

background:rgba(0, 0, 0, 0.05);
border:1px solid rgba(255,255,255,0.1);
border-radius:16px;
backdrop-filter:blur(10px);
transition:.3s ease;
}

.glass:hover{
  opacity:1;
  color: rgb(220, 173, 102);

}




.btn{
  padding:14px 24px;
  border-radius:999px;
  border:1px solid var(--yellow);
  color:var(--white);
  text-decoration:none;
  transition:.3s;
}

.btn.primary{
  background:var(--yellow);
  color:#000;
  font-weight:700;
}

.hero{
  min-height:100vh;
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:60px;
  align-items:center;
  padding-top:120px;
}

.eyebrow{
  color:var(--yellow);
  letter-spacing:2px;
  margin-bottom:16px;
}

.hero h1{
  font-size:clamp(3rem,5vw,5.5rem);
  line-height:1.05;
}

.hero p{
  color:var(--muted);
  margin:28px 0;
  line-height:1.8;
}

.actions{
  display:flex;
  gap:16px;
}

.hero-visual{
  position:relative;
}

.hero-visual img{
  width:100%;
  filter:drop-shadow(0 0 50px rgba(124, 120, 99, 0.2));
}

.callout{
  position:absolute;
  width:220px;
  padding:18px;
}


.c1{top:10%;right:-30px;}
.c2{top:45%;right:-50px;}
.c3{bottom:10%;left:-40px;}


section{
  padding:120px 0;
}

.section-title{
  text-align:center;
  margin-bottom:50px;
}

.section-title h2{
  font-size:3rem;
}

.compare{
  display:grid;
