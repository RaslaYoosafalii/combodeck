}

.compare-card{
  padding:40px;
}

.compare-card ul{
  margin-top:20px;
  line-height:2;
  color:var(--muted);
}
.compare-card ul:hover{
  opacity:1;
color: rgb(220, 173, 102);
}

.cards{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:24px;
}

.card{
  padding:32px;
