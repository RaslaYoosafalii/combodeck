<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Edit Profile</title>

  <style>
    * {
      box-sizing: border-box;
      font-family: Arial, sans-serif;
    }

    
    body {
  margin: 0;
  background: #0a0e11;
  color: white;
    }
  
    /* ===== LAYOUT ===== */
    .profile-wrapper {
      display: flex;
      padding: 40px 60px;
      margin-top: 110px;
      gap: 40px;
      align-items: flex-start; 
    }

    /* ===== SIDEBAR ===== */
    .profile-main {
  flex: 1;
  min-width: 0;
}


    /* ===== PROFILE CARD ===== */
    .profile-card {
   flex: 1;
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 16px;
  padding: 40px;
  box-shadow: 0 10px 30px rgba(0,0,0,0.35);
  backdrop-filter: blur(10px);
  position: relative;
    }

    .profile-title {
  text-align: center;
  font-size: 28px;
  letter-spacing: 2px;
  margin-bottom: 35px;
  border-bottom: 1px solid rgba(255,255,255,0.08);
  padding-bottom: 10px;
  color: white;
    }

    /* ===== CONTENT ===== */
    .profile-content {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 25px;
    }

    .avatar-large {
  width: 120px;
  height: 120px;
  border-radius: 50%;
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.08);
  margin-bottom: 20px;
    }

    .field-group {
      display: flex;
      align-items: center;
      gap: 16px;
      width: 100%;
      max-width: 480px;
    }

    .field-group label {
      width: 90px;
      text-align: right;
      font-weight: 600;
    }

    .field-input {
  flex: 1;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.08);
  color: white;
  border-radius: 6px;
  padding: 10px 14px;
  font-size: 14px;
  outline: none;
    }

    .edit-icon {
  cursor: pointer;
  font-size: 16px;
  color: rgba(255,255,255,0.75);
    }

    .change-password-btn {
      margin-top: 15px;
      background: #5a5553;
      color: #fff;
      border: none;
      padding: 10px 24px;
      border-radius: 6px;
      cursor: pointer;
      font-size: 14px;

        background: rgba(255,255,255,0.04);
  color: white;
  border: 1px solid rgba(255,255,255,0.08);
    }

    .save-btn {
      position: absolute;
      bottom: 30px;
      right: 40px;
      background: #5a5553;
      color: #fff;
      border: none;
      padding: 10px 22px;
      border-radius: 6px;
      font-size: 14px;
      cursor: pointer;

        background: rgba(255,255,255,0.04);
  color: white;
  border: 1px solid rgba(255,255,255,0.08);
    }

    
input[type="file"] {
  color: rgba(255,255,255,0.8);
  font-size: 13px;
  margin-bottom: 10px;
}

input[type="file"]::file-selector-button {
  background: rgba(255,255,255,0.05);
  color: white;
  border: 1px solid rgba(255,255,255,0.08);
  padding: 10px 16px;
  border-radius: 8px;
  cursor: pointer;
  margin-right: 14px;
  transition: 0.3s;
}

input[type="file"]::file-selector-button:hover {
  background: rgba(255,255,255,0.08);
}
.change-password-btn {
  position: absolute;
  top: 110px;
  right: 40px;
  background: rgba(255,255,255,0.05);
  color: white;
  border: 1px solid rgba(255,255,255,0.08);
  padding: 10px 18px;
  border-radius: 8px;
  cursor: pointer;
  font-size: 13px;
  transition: 0.3s;
}

.change-password-btn:hover {
  background: rgba(255,255,255,0.08);
}
.profile-main {
  flex: 1;
}

.breadcrumb {
  margin-bottom: 18px;
  font-size: 14px;
  color: rgba(255,255,255,0.65);
  display: flex;
  align-items: center;
  gap: 10px;
}

.breadcrumb a {
  color: rgba(255,255,255,0.75);
  text-decoration: none;
  transition: 0.2s;
}

.breadcrumb a:hover {
  color: white;
}
  </style>
</head>

<body>
 <%- include('../partials/user/loggedinHeader') %>
<div class="profile-wrapper">

  <!-- ===== SIDEBAR ===== -->
<%- include('../partials/user/profileSidebar') %>

  <!-- ===== EDIT PROFILE CARD ===== -->
<div class="profile-main">
  <div class="breadcrumb">
    <a href="/profile">Profile</a>
    <span>›</span>
    <span>Edit Profile</span>
  </div>
  <section class="profile-card">

    <h2 class="profile-title">PROFILE</h2>

   <form method="POST" action="/profile/edit?_method=PATCH" class="profile-content" enctype="multipart/form-data">


 <% if (user?.profileImage) { %>
<div style="position: relative;">
  <img
    src="<%= user.profileImage %>"
    alt="Profile Image"
    class="avatar-large"
    style="object-fit: cover;"
  />
  <span
    onclick="deleteProfileImage()"
    style="
      position: absolute;
      top: 5px;
      right: 5px;
      background: #000;
      color: #fff;
      width: 22px;
      height: 22px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
      cursor: pointer;
    "
    title="Delete profile photo"
  >
    ✕
  </span>
</div>

<% } else { %>
  <div class="avatar-large"></div>
<% } %>
<input
  type="file"
  name="profileImage"
  accept="image/png, image/jpeg"
  style="margin-bottom: 10px;"
/>



      <div class="field-group">
        <label>Name:</label>
        <input
          type="text"
          name="name"
          class="field-input"
          value="<%= user?.name || '' %>"
        />
        <span class="edit-icon">✎</span>
      </div>

      <div class="field-group">
        <label>Email:</label>
        <input
          type="email"
          name="email"
          class="field-input"
          value="<%= user?.email || '' %>"
        />
        <span class="edit-icon">✎</span>
      </div>

      <div class="field-group">
        <label>Phone:</label>
        <input
          type="text"
          name="mobileNumber"
          class="field-input"
          value="<%= user?.mobileNumber || '' %>"
        />
        <span class="edit-icon">✎</span>
      </div>

      <button
        type="button"
        class="change-password-btn"
        onclick="location.href='/profile/change-password'"
      >
       ✎ Change password
      </button>

      <button type="submit" class="save-btn">
        Save changes
      </button>

    </form>

  </section>
   </div>
</div>
<%- include('../partials/user/footer') %>
</body>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<% if (typeof updatedFields !== 'undefined' && updatedFields.length) { %>
<script>
  const fields = <%- JSON.stringify(updatedFields) %>;

  let text = '';
  if (fields.length === 1) {
    text = `${fields[0]} updated successfully`;
  } else if (fields.length === 2) {
    text = `${fields[0]} and ${fields[1]} updated successfully`;
  } else {
    text = `${fields.join(', ')} updated successfully`;
  }

  Swal.fire({
    icon: 'success',
    title: 'Profile Updated',
    text,
    confirmButtonColor: '#4a4745'
  }).then(() => {
    window.location.href = '/profile';
  });
</script>
<% } %>
<% if (typeof message !== 'undefined' && message) { %>
<script>
  Swal.fire({
    icon: 'error',
    title: 'Update Failed',
    text: '<%= message %>',
    confirmButtonColor: '#4a4745'
  });
</script>
<% } %>
<script>
  function deleteProfileImage() {
    Swal.fire({
      title: 'Delete profile photo?',
      text: 'This action cannot be undone',
      icon: 'warning',
      showCancelButton: true,
      confirmButtonColor: '#5a5553',
      cancelButtonColor: '#aaa',
      confirmButtonText: 'Yes, delete'
    }).then(async (result) => {
      if (!result.isConfirmed) return;

      const res = await fetch('/profile/delete-image', {
        method: 'DELETE'
      });

      const data = await res.json();

      if (data.success) {
        Swal.fire({
          icon: 'success',
          title: 'Deleted',
          text: 'Profile photo removed'
        }).then(() => {
          location.reload();
        });
      } else {
        Swal.fire('Error', 'Unable to delete image', 'error');
      }
    });
  }
</script>

</html>
