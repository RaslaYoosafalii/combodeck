<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Order Details</title>
<style>
.container{
  max-width:1000px;
  margin:0;
  font-family:Arial;
  color:white;
}

h2, h3 {
  color: white;
  margin-bottom: 14px;
}

p {
  color: rgba(255,255,255,0.75);
  line-height: 1.7;
}

.item{
  display:flex;
  gap:15px;
  margin-bottom:20px;
  padding:16px;
  border:1px solid rgba(255,255,255,0.08);
  background: rgba(255,255,255,0.03);
  border-radius:12px;
}

.item img{
  width:80px;
  height:100px;
  object-fit:cover;
  border-radius:8px;
}

.badge{
  padding:4px 10px;
  border-radius:14px;
  background: rgba(255,255,255,0.06);
  border:1px solid rgba(255,255,255,0.08);
  color:white;
  font-size:13px;
}

.btn{
  padding:8px 16px;
  border-radius:20px;
  border:1px solid rgba(255,255,255,0.08);
  cursor:pointer;
  font-size:14px;
  background: rgba(255,255,255,0.04);
  color:white;
  transition:0.3s ease;
}

.btn:hover{
  background: rgba(255,255,255,0.08);
}

.btn-dark{
  background: rgba(255,255,255,0.08);
  color:#fff;
}

.btn-outline{
  background: rgba(255,255,255,0.04);
  border:1px solid rgba(255,255,255,0.08);
  color:white;
}
</style>
</head>

<body>


<div class="container">
<h2>Order <%= order.orderId %></h2>

<p>
Order Date: <%= new Date(order.orderDate).toDateString() %><br>
Payment: <%= order.paymentMethod %> | <%= order.paymentStatus %><br>
Status: <%= order.orderStatus %><br>
Order total: ₹<%= order.finalPrice %>
<% if(order.deliveredOn){ %>
<br>Delivered On: <%= new Date(order.deliveredOn).toDateString() %>
<% } %>
</p>

<h3>Delivery Address</h3>
<p>
<%= order.address.name %>, <%= order.address.address %>,
<%= order.address.city %> - <%= order.address.pincode %>
</p>

<h3>Items</h3>

<% order.orderedItem.forEach(i => { %>
<div class="item">
  <img src="<%= imageUrl(i.productImages[0]) %>">

  <div>
    <strong><%= i.productName %></strong><br>
    Size: <%= i.size %><br>
    Qty: <%= i.quantity %><br>
    <% if (i.couponShare > 0) { %>
  Price:
  <span style="text-decoration:line-through;color:#888">
    ₹<%= i.offerPrice %>
  </span>
  ₹<%= i.offerPrice - i.couponShare.toFixed(2) %><br>
<% } else { %>
  Price: ₹<%= i.offerPrice.toFixed(2) %><br>
<% } %>

   <span class="badge">
  <% if (i.orderStatus === 'rejected') { %>
    Return request rejected (Delivered)
  <% } else { %>
    <%= i.orderStatus %>
  <% } %>
</span><br><br>

 
<% if (
  order.orderStatus !== 'failed' &&
  !['delivered', 'cancelled', 'returnRequested', 'returned', 'failed','rejected'].includes(i.orderStatus)
) { %>

  <button class="btn btn-dark"
    onclick="cancelItem('<%= order.orderId %>', '<%= i.product %>')">
    Cancel Item
  </button>
<% } %>

<% if (i.orderStatus === 'delivered') { %>
  <button class="btn btn-dark"
    onclick="returnItem('<%= order.orderId %>', '<%= i.product %>')">
    Return Item
  </button>
<% } %>

<% if (i.orderStatus === 'returnRequested') { %>
  <button class="btn btn-outline"
    onclick="cancelReturn('<%= order.orderId %>', '<%= i.product %>')">
    Cancel Return Request
  </button>
<% } %>


  </div>
</div>
<% }) %>

</div>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>



</body>
</html>
