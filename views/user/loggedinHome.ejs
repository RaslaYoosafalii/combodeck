
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Combodeck</title>
  <style>
    /* General Reset */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Arial', sans-serif;
      
    }
body {
  color: #ffffff;
  background: #0a0e11;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}
main {
  flex: 1;
}




  /* Categories */
    .categories {
      text-align: center;
      margin-top: 30px;
      padding-top: 10px;
 
    }




    .categories .btn {
      margin: 15px 0;
    }

    .category-list {
      display: flex;
      justify-content: center;
      margin-top: 20px;
      
    }

    .category img {
      width: 100%;
    }

    .category p {
      margin-top: 10px;
      font-weight: bold;
      text-align: left;
       margin-bottom: 60px;
       
    }
    .category p:hover {
     text-decoration: underline;
       
    }
    /* New Arrivals */
    .new-arrivals {
      text-align: center;
      padding: 50px 60px;
    }

    .products {
      display: flex;
      justify-content: center;
      gap: 30px;
      margin-top: 20px;
    }

    .product img {
      width: 220px;
      border-radius: 8px;
    }

    .product h3 {
      font-size: 15px;
      margin: 10px 0 5px;
    }

.product p {
  font-size: 13px;
  color: rgba(255,255,255,0.65);
}

    .product span {
      font-weight: bold;
    }

.new-arrivals,
.categories {
  background: rgba(255,255,255,0.02);
}


.wrapper{
  margin:30px auto 60px;
  width:min(1500px, calc(100% - 20px));
  min-height:800px;
  height:auto;
  border-radius:28px;
  position:relative;
  overflow:hidden;
  background-image:url("/images/finalHome.png");
  background-size:contain;
  background-position:center;
  background-repeat:no-repeat;
  box-shadow:0 40px 100px rgba(0,0,0,0.7);
  padding:30px;
}

.info-cards{
  position: absolute;
  right: 60px;
  top: 455px;
  display: flex;
  flex-direction: column;
  gap: 25px;
}

.info-cards{
position:absolute;
right:60px;
top:455px;
display:flex;
flex-direction:column;
gap:25px;
}

.card{
width:260px;
padding:22px;

background:rgba(0, 0, 0, 0.05);
border:1px solid rgba(255,255,255,0.1);
border-radius:16px;
backdrop-filter:blur(10px);
}
.card:hover{
opacity:1;
color: rgb(220, 173, 102);
}

.card h4{
font-size:13px;
letter-spacing:2px;
margin-bottom:10px;
}

.card p{
font-size:12px;
opacity:.7;
line-height:1.6;
}



.left-info{
  position: absolute;
  left: 60px;
  bottom: 30px;
  color: white;
}

.left-info h2{
  font-size: 22px;
  letter-spacing: 3px;
  line-height: 1.5;
}
.products,
.category-list{
  flex-wrap:wrap;
  width:100%;
}

.product,
.category{
  min-width:0;
}

.product img{
  width:100%;
  max-width:220px;
  height:auto;
}

.category img{
  width:100%;
  height:auto;
  display:block;
}
.category-list {
  display:grid;
  grid-template-columns:repeat(4, minmax(0, 1fr));
  gap:24px;
  margin-top:20px;
  width:100%;
  align-items:start;
}
.category{
  width:100%;
  text-align:left;
}

.category a{
  display:block;
  width:100%;
}

.category img{
  width:100%;
  aspect-ratio:1/1;
  object-fit:cover;
}

@media(max-width:1024px){
  .wrapper{
    min-height:700px;
    padding:24px;
  }

  .info-cards{
    right:30px;
    top:auto;
    bottom:30px;
    gap:18px;
  }

  .card{
    width:220px;
    padding:18px;
  }

  .left-info{
    left:30px;
    bottom:30px;
  }

  .left-info h2{
    font-size:18px;
  }

  .new-arrivals{
    padding:40px 24px;
  }
}

@media(max-width:768px){
  .wrapper{
    min-height:650px;
    background-size:contain;
    background-position:center top;
    padding:20px;
  }

  .info-cards{
    position:static;
    margin-top:280px;
    display:flex;
    gap:16px;
    width:100%;
    margin-bottom: 0p;
  }

  .card{
    width:100%;
  }

  .left-info{
    margin-top:0px;
  }

  .left-info h2{
    display: none;
  }

  .products,
  .category-list{
    gap:20px;
    justify-content:center;
  }

  .product{
    width:calc(50% - 20px);
  }

.category-list{
  grid-template-columns:repeat(2, minmax(0, 1fr));
}

  .new-arrivals{
    padding:40px 20px;
  }
}

@media(max-width:480px){
  .wrapper{
    width:calc(100% - 12px);
    min-height:auto;
    padding:16px;
    border-radius:18px;
    background-size:contain;
    background-position:center top;
  }

  .info-cards{
    margin-top:180px;
    flex-direction:column;
    gap:14px;
  }

  .card{
    width:100%;
    padding:16px;
  }

  .card h4{
    font-size:11px;
  }

  .card p{
    font-size:11px;
    line-height:1.5;
  }

  .left-info{
    margin-top:0px;
  }

  .left-info h2{
  display: none;
  }

  .product{
  grid-template-columns:1fr;
  gap:18px;
  }
.category-list{
  grid-template-columns:1fr;
  gap:18px;
}

  .product img{
    max-width:100%;
  }

  .new-arrivals{
    padding:30px 16px;
  }
}
  </style>
</head>
<body>
  <!-- Navbar -->
  <%-include('../partials/user/loggedinHeader')%>
<!-- hero section -->
<!-- Hero section -->

  <div class="wrapper">

    <div class="info-cards">
      <div class="card">
        <h4>ADVANCED TECHNOLOGY</h4>
        <p>
          Leverage the latest in audio technology with our state-of-the-art
          features and functionalities.
        </p>
      </div>

      <div class="card">
        <h4>FUTURISTIC DESIGN</h4>
        <p>
          Step into the future with our sleek, minimalist design that fits
          seamlessly into any environment.
        </p>
      </div>
    </div>

    <div class="left-info">
      <h2>
        UNMATCHED <br>
        SOUND QUALITY
      </h2>
    </div>
  </div>



  <!-- New Arrivals -->
  <section class="new-arrivals" >
    <h2>NEW ARRIVALS</h2>
    <div class="products" >
  <% if (latestProducts && latestProducts.length > 0) { %>
    <% latestProducts.forEach(function(product) { %>
      <div class="product" style="gap: 0;">
        <a href="/product/<%= product._id %>" style="text-decoration:none; color:inherit;">
          <img 
            src="<%= product.images && product.images.length > 0 ? imageUrl(product.images[0]) : '/images/product1.png' %>" 
            alt="<%= product.productName %>" style="border-radius: 0px;">
          <h3><%= product.productName %></h3>
        
          <span style=" font-weight:550; font-size: 15px;">Rs. <%= product.finalPrice ? product.finalPrice.toFixed(2) : '0.00' %></span>
        </a>
      </div>
    <% }) %>
  <% } else { %>
    <p>No new arrivals available.</p>
  <% } %>
</div>
  </section>
  <!-- Explore by Category -->
  <section class="categories">
    <h2>EXPLORE BY CATEGORY</h2>
     <div class="category-list"  >
  <% if (categories && categories.length > 0) { %>
    <% categories.forEach(function(cat) { %>
      <div class="category" >
        <a href="/products?category=<%= cat._id %>" style="text-decoration:none; color:inherit;">
         <img  src="<%= imageUrl(cat.image) ?   imageUrl(cat.image) : '/images/catimage1.png' %>" alt="<%= cat.name %>" >
          <p style="margin-bottom: 0; text-decoration: none;"><%= cat.name.toUpperCase() %></p>
          <p style=" margin-top: 2px; font-size: 14px; font-weight: lighter;font-family:'Franklin Gothic Medium', 'Arial Narrow', Arial, sans-serif;">EXPLORE</p>        </a>
      </div>
    <% }) %>
  <% } else { %>
    <p>No categories available</p>
  <% } %>
</div>
   
  </section>

  <!-- Footer -->
  <%-include('../partials/user/footer')%>

  <script>
    
    window.addEventListener('pageshow', function (event) {
      if (event.persisted) {
        window.location.reload();
      }
    });
  </script>
</body>
</html>
