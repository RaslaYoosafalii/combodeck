<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Combodeck</title>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Elfé Lorienveil</title>
  <style>
    /* General Reset */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Arial', sans-serif;
      
    }
body {
  color: #ffffff;
  background: #0a0e11;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}
main {
  flex: 1;
}


   

    /* Hero */
    .hero {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
    }

    .hero img {
      width: 100%;
        border-radius: 5px;
    }

    .hero .center {
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
    }

    .hero h2 {
      font-size: 28px;
      font-weight: bold;
    }

    .hero h2 span {
      font-size: 40px;
    }

    .hero .btn {
      margin-top: 15px;
    }

  /* Categories */
    .categories {
      text-align: center;
      margin-top: 30px;
      padding-top: 10px;
 
    }




    .categories .btn {
      margin: 15px 0;
    }

    .category-list {
      display: flex;
      justify-content: center;
      margin-top: 20px;
      
    }

    .category img {
      width: 100%;
    }

    .category p {
      margin-top: 10px;
      font-weight: bold;
      text-align: left;
       margin-bottom: 60px;
       
    }
    .category p:hover {
     text-decoration: underline;
       
    }
    /* New Arrivals */
    .new-arrivals {
      text-align: center;
      padding: 50px 60px;
    }

    .products {
      display: flex;
      justify-content: center;
      gap: 30px;
      margin-top: 20px;
    }

    .product img {
      width: 220px;
      border-radius: 8px;
    }

    .product h3 {
      font-size: 15px;
      margin: 10px 0 5px;
    }

.product p {
  font-size: 13px;
  color: rgba(255,255,255,0.65);
}

    .product span {
      font-weight: bold;
    }

.new-arrivals,
.categories {
  background: rgba(255,255,255,0.02);
}


.wrapper{
  margin: 0 auto;
  width: 100%;
  margin-bottom: 60px;
  margin-top: 30px;
  max-width: 1500px;
  height: 800px;
  border-radius: 28px;
  position: relative;
  overflow: hidden;
  background-image: url("/images/finalHome.png");
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  box-shadow: 0 40px 100px rgba(0,0,0,0.7);
  padding: 30px;
}

.info-cards{
  position: absolute;
  right: 60px;
  top: 455px;
  display: flex;
  flex-direction: column;
  gap: 25px;
}

.info-cards{
position:absolute;
right:60px;
top:455px;
display:flex;
flex-direction:column;
gap:25px;
}

.card{
width:260px;
padding:22px;

background:rgba(0, 0, 0, 0.05);
border:1px solid rgba(255,255,255,0.1);
border-radius:16px;
backdrop-filter:blur(10px);
}
.card:hover{
opacity:1;
color: rgb(220, 173, 102);
}

.card h4{
font-size:13px;
letter-spacing:2px;
margin-bottom:10px;
}

.card p{
font-size:12px;
opacity:.7;
line-height:1.6;
}



.left-info{
  position: absolute;
  left: 60px;
  bottom: 30px;
  color: white;
}

.left-info h2{
  font-size: 22px;
  letter-spacing: 3px;
  line-height: 1.5;
}
  </style>
</head>
<body>
  <!-- Navbar -->
  <%-include('../partials/user/loggedinHeader')%>
<!-- hero section -->
<!-- Hero section -->

  <div class="wrapper">

    <div class="info-cards">
      <div class="card">
        <h4>ADVANCED TECHNOLOGY</h4>
        <p>
          Leverage the latest in audio technology with our state-of-the-art
          features and functionalities.
        </p>
      </div>

      <div class="card">
        <h4>FUTURISTIC DESIGN</h4>
        <p>
          Step into the future with our sleek, minimalist design that fits
          seamlessly into any environment.
        </p>
      </div>
    </div>

    <div class="left-info">
      <h2>
        UNMATCHED <br>
        SOUND QUALITY
      </h2>
    </div>
  </div>



  <!-- New Arrivals -->
  <section class="new-arrivals" >
    <h2>NEW ARRIVALS</h2>
    <div class="products" style="gap: 2px; text-align: left; ">
  <% if (latestProducts && latestProducts.length > 0) { %>
    <% latestProducts.forEach(function(product) { %>
      <div class="product" style="gap: 0;">
        <a href="/product/<%= product._id %>" style="text-decoration:none; color:inherit;">
          <img 
            src="<%= product.images && product.images.length > 0 ? imageUrl(product.images[0]) : '/images/product1.png' %>" 
            alt="<%= product.productName %>" style="border-radius: 0px;">
          <h3><%= product.productName %></h3>
        
          <span style=" font-weight:550; font-size: 15px;">Rs. <%= product.finalPrice ? product.finalPrice.toFixed(2) : '0.00' %></span>
        </a>
      </div>
    <% }) %>
  <% } else { %>
    <p>No new arrivals available.</p>
  <% } %>
</div>
  </section>
  <!-- Explore by Category -->
  <section class="categories" style="padding-left: 10px ; padding-right: 10px ;">
    <h2>EXPLORE BY CATEGORY</h2>
     <div class="category-list"  >
  <% if (categories && categories.length > 0) { %>
    <% categories.forEach(function(cat) { %>
      <div class="category" >
        <a href="/products?category=<%= cat._id %>" style="text-decoration:none; color:inherit;">
         <img  src="<%= imageUrl(cat.image) ?   imageUrl(cat.image) : '/images/catimage1.png' %>" alt="<%= cat.name %>" >
          <p style="margin-bottom: 0; text-decoration: none;"><%= cat.name.toUpperCase() %></p>
          <p style=" margin-top: 2px; font-size: 14px; font-weight: lighter;font-family:'Franklin Gothic Medium', 'Arial Narrow', Arial, sans-serif;">EXPLORE</p>        </a>
      </div>
    <% }) %>
  <% } else { %>
    <p>No categories available</p>
  <% } %>
</div>
   
  </section>

  <!-- Footer -->
  <%-include('../partials/user/footer')%>

  <script>
    
    window.addEventListener('pageshow', function (event) {
      if (event.persisted) {
        window.location.reload();
      }
    });
  </script>
</body>
</html>
