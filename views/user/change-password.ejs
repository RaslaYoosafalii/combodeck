<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Change Password</title>

  <link href="https://fonts.googleapis.com/css2?family=Lora:wght@700&family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
* {
  box-sizing: border-box;
  font-family: "Poppins", sans-serif;
}

body {
  min-height: 100vh;
  margin: 0;
  background: #0a0e11;
  color: white;
  display: flex;
  flex-direction: column;
}

.page-container {
  width: 100%;
  max-width: 1100px;
  margin: 110px auto 60px;
  padding: 0 20px;
}

.breadcrumb {
  margin-bottom: 18px;
  font-size: 14px;
  color: rgba(255,255,255,0.65);
  display: flex;
  align-items: center;
  gap: 10px;
}

.breadcrumb a {
  color: rgba(255,255,255,0.75);
  text-decoration: none;
}

.breadcrumb a:hover {
  color: white;
}

.card {
  width: 100%;
  border-radius: 16px;
  padding: 60px;
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.08);
  backdrop-filter: blur(10px);
  box-shadow: 0 10px 30px rgba(0,0,0,0.35);
}

h1 {
  font-size: 40px;
  margin: 0 0 18px;
  text-align: center;
  color: white;
}

.lead {
  max-width: 680px;
  margin: 0 auto 18px;
  text-align: center;
  font-size: 16px;
  color: rgba(255,255,255,0.75);
}

form {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14px;
  margin-top: 8px;
}

.inp {
  width: 55%;
  max-width: 560px;
  padding: 16px 18px;
  border-radius: 8px;
  border: 1px solid rgba(255,255,255,0.08);
  background: rgba(255,255,255,0.04);
  color: white;
  font-size: 14px;
  outline: none;
}

.inp:focus {
  border-color: rgba(255,255,255,0.15);
}

.btn {
  width: 55%;
  max-width: 560px;
  padding: 14px;
  border-radius: 8px;
  border: 1px solid rgba(255,255,255,0.08);
  background: rgba(255,255,255,0.04);
  color: white;
  font-size: 16px;
  cursor: pointer;
  transition: 0.3s;
  margin-top: 6px;
}

.btn:hover {
  background: #d0a65c42;
}

.link-row {
  margin-top: 35px;
  text-align: center;
}

.link-row a {
  color: #ffffffb1;
  font-size: 14px;
  text-decoration: none;
}

.link-row a:hover {
  color: rgba(218, 182, 92, 0.738);
  text-decoration: underline;
}

@media (max-width:780px) {
  .card {
    padding: 40px 24px;
  }

  .inp,
  .btn {
    width: 92%;
  }

  h1 {
    font-size: 34px;
  }
}
</style>
</head>
<body>
  <%-include('../partials/user/header')%>

  <div class="page-container">
    <div class="breadcrumb">
      <a href="/login">Login</a>
      <span>›</span>
      <a href="/forgot-password">Forgot Password</a>
      <span>›</span>
      <a href="/forgot-verify">OTP Verification</a>
      <span>›</span>
      <span>Change Password</span>
    </div>

    <div class="card">
    <h1>Change Password</h1>
    <p class="lead">Please confirm your password</p>

    <% if (typeof message !== 'undefined' && message) { %>
      <script>
        document.addEventListener('DOMContentLoaded', ()=> {
          Swal.fire({ icon: 'info', title: 'Notice', text: "<%= message.replace(/"/g, '\\"') %>" });
        });
      </script>
    <% } %>

    <form id="changeForm" method="POST" action="/change-password" novalidate>
      <input class="inp" name="newPassword" type="password" placeholder="New password" required />
      <input class="inp" name="confirmPassword" type="password" placeholder="Confirm Password" required />
      <button class="btn" id="changeBtn" type="submit">Change Password</button>
    </form>

    <div class="link-row">
      <a href="/login" >Go back to Login page</a>
    </div>
  </div>
  </div>
  <script>
    document.getElementById('changeForm').addEventListener('submit', async function(e){
      e.preventDefault();
      const newP = this.newPassword.value.trim();
      const cP = this.confirmPassword.value.trim();

      if (!newP || !cP) {
        Swal.fire({ icon:'error', title:'Missing fields', text:'Please fill both password fields.'});
        return;
      }
      if (newP !== cP) {
        Swal.fire({ icon:'error', title:'Mismatch', text:'Passwords do not match.'});
        return;
      }
      
if (newP.length < 8) {
  Swal.fire({
    icon:'error',
    title:'Weak password',
    text:'Password must be at least 8 characters long.'
  });
  return;
}

const alpha = /[A-Za-z]/;
const digit = /\d/;

if (!alpha.test(newP) || !digit.test(newP)) {
  Swal.fire({
    icon:'error',
    title:'Weak password',
    text:'Password must contain at least one alphabet and one digit.'
  });
  return;
}

      const changeBtn = document.getElementById('changeBtn');
      changeBtn.disabled = true;

      try {
        const res = await fetch('/change-password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ newPassword: newP, confirmPassword: cP })
        });

        const data = await res.json();
        if (res.ok && data?.success) {
          await Swal.fire({ icon:'success', title:'Success', text: data.message || 'Password changed successfully' });
          // redirect to login
          window.location.href = data.redirectUrl || '/login';
        } else {
          Swal.fire({ icon:'error', title:'Failed', text: data?.message || 'Failed to change password' });
        }
      } catch (err) {
        Swal.fire({ icon:'error', title:'Server error', text:'Unable to change password. Please try again later.' });
      } finally {
        changeBtn.disabled = false;
      }
    });
  </script>
    <%- include('../partials/user/footer') %>

</body>
</html>
