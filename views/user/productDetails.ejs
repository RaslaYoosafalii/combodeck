<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<title><%= product.productName %></title>
<meta name="viewport" content="width=device-width, initial-scale=1">

<style>
      * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Arial', sans-serif;
    }

:root{
  --bg: #0a0e11;
  --text-main: #ffffff;
  --muted: rgba(255,255,255,0.65);
  --accent: rgb(220, 173, 102);
  --card-bg: rgba(255,255,255,0.03);
  --border: rgba(255,255,255,0.08);
}

body {
  background: var(--bg);
  color: var(--text-main);
  font-family: 'Inter', sans-serif;
}

    /* Navbar */
    .navbar {
        background: #0a0e11!important;
    }


    /* Hero */
    .hero {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 15px;
      padding: 40px 60px;
    }

    .hero img {
      width: 100%;
      border-radius: 8px;
    }

    .hero .center {
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
    }

    .hero h2 {
      font-size: 28px;
      font-weight: bold;
    }

    .hero h2 span {
      font-size: 40px;
    }

    .hero .btn {
      margin-top: 15px;
    }

    /* Categories */
    .categories {
      text-align: center;
      padding: 50px 60px;
    }

    .categories .btn {
      margin: 15px 0;
    }

    .category-list {
      display: flex;
      justify-content: center;
      gap: 30px;
      margin-top: 20px;
    }

    .category img {
      width: 200px;
      border-radius: 8px;
    }

    .category p {
      margin-top: 10px;
      font-weight: bold;
    }

    /* New Arrivals */
    .new-arrivals {
      text-align: center;
      padding: 50px 60px;
    }

    .products {
      display: flex;
      justify-content: center;
      gap: 30px;
      margin-top: 20px;
    }

    .product img {
      width: 220px;
      border-radius: 8px;
    }

    .product h3 {
      font-size: 15px;
      margin: 10px 0 5px;
    }

    .product p {
      font-size: 13px;
      color: #555;
    }

    .product span {
      font-weight: bold;
    }


body {
    font-family: Arial, sans-serif;
    color: #222;
}

.container {
  max-width: 1250px;
  margin: 120px auto 40px;
  padding: 20px;
  background: transparent;
}

.breadcrumbs {
    font-size: 14px;
    margin-bottom: 20px;
    color: var(--muted);
}

.breadcrumbs a {
    color: var(--muted);
    text-decoration: none;
}
.breadcrumbs a:hover {
  color: var(--accent);
}


.details-layout {
    display: flex;
    gap: 40px;
}

/* LEFT IMAGE SECTION */
.left-images {
    width: 55%;
}

.main-img-wrap {
    width: 100%;
    height: 600px;
  border-radius: 16px;
  overflow: hidden;
  background: var(--card-bg);
  border: 1px solid var(--border);
    
}

.main-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    cursor: zoom-in;
    transition: transform 0.3s ease;
}

.main-img-wrap img:hover {
    transform: scale(1.08);
}

.thumbnail-grid {
    margin-top: 20px;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
   
}

.thumbnail-grid img {
    width: 100%;
    height: 170px;
    object-fit: cover;
    cursor: pointer;
    opacity: 0.8;
    transition: 0.2s;
  border-radius: 10px;
  border: 1px solid var(--border);
}
.thumbnail-grid img:hover{
   transform: scale(1.08);
}

.thumbnail-active {
    outline: 2px solid var(--accent);
    opacity: 1 !important;
}

/* RIGHT INFO SECTION */
.right-info {
    width: 45%;
}

.product-title {
  font-size: 26px;
  font-weight: 600;
  color: white;
}

.product-price {
    font-size: 22px;
    font-weight: bold;
    margin-top: 10px;
    color: white;
}


.mrp-text {
    font-size: 12px;
    margin-top: 5px;
    color: var(--muted);
}

.color-text {
    margin-top: 15px;
    font-size: 13px;
    font-weight: bold;
    color: var(--muted);
}
.subcat-text {
  color: var(--muted);
}

.size-box-wrap {
    margin-top: 20px;
}

.size-box-wrap h4 {
    margin-bottom: 12px;
    font-size: 14px;
}

.size-btns {
    display: flex;
    gap: 10px;
}

.size-option {
  padding: 10px 18px;
  border: 1px solid var(--border);
  border-radius: 6px;
  cursor: pointer;
  color: white;
  background: rgba(255,255,255,0.04);
  transition: 0.2s;
}

.size-option.disabled {
    opacity: 0.3;
    cursor: not-allowed;
    border-color: var(--accent);
}

.size-option.active {
  background: rgba(220, 173, 102, 0.2);
  color: var(--accent);
  border-color: var(--accent);
}

.add-btn {
    margin-top: 25px;
    width: 240px;
    padding: 15px;
      background: #91857326;
  color: white;
  border: 0.1px solid grey;
  border-radius: 30px;
  text-align: center;
  cursor: pointer;
  font-size: 15px;
  backdrop-filter: blur(10px);
  transition: 0.2s;
}
.add-btn:hover {
  background: rgba(220, 173, 102, 0.3);
  color: var(--accent);
  border-color: var(--accent);

}
/* DESCRIPTION SECTION */
.desc-section {
    margin-top: 40px;
}

.desc-title {
    font-weight: bold;
    font-size: 16px;
    color: white;
}

.desc-text {
    margin-top: 10px;
    font-size: 14px;
    line-height: 1.6;
    white-space: pre-line;
    color: var(--muted);
}

.recommend-title {
    margin-top: 60px;
    font-size: 20px;
    font-weight: bold;
    color: #e4e4e4;
}

.recommend-grid {
    margin-top: 20px;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    margin-bottom: 80px;
    border-radius: 14px;
    
}

.recommend-grid img {
    width: 100%;
    height: 400px;
    object-fit: cover;
}

.recommend-grid a {
    text-decoration: none;
    color: inherit;
    
}
.unavailable-box {
  border: 0.1px solid grey;
 background: #91857326;
  padding:20px;
  border-radius:10px;
  margin-bottom:20px;
}
button[disabled] {
  opacity:0.5;
  cursor:not-allowed;
}
.disabled-action {
  opacity: 0.4;
  cursor: not-allowed;
  pointer-events: auto; /* allow click so message logic still works */
}
#wishlistIcon {
  transition: 0.2s ease;
}

#wishlistIcon:hover {
  transform: scale(1.12);
}

</style>

</head>
<body>

  <% if (isLoggedIn) { %>
  <%- include('../partials/user/loggedinHeader') %>
<% } else { %>
  <%- include('../partials/user/header') %>
<% } %>
<div class="container">

    <!-- BREADCRUMB -->
    <div class="breadcrumbs">
        <a href="/">Home</a> → 
        <a href="/products">All Products</a> → 
        <%= category ? category.name : "" %>
    </div>

    <div class="details-layout">

        <!-- LEFT IMAGES -->
        <div class="left-images">
            <div class="main-img-wrap">
                <img id="mainImg" src="<%= imageUrl(product.images[0]) %>" alt="Product Image">
            </div>

            <div class="thumbnail-grid">
                <% product.images.forEach(function(img, i) { %>
                  
                    <img 
                      src="<%= imageUrl(img )%>" 
                      onclick="changeImage(this)" 
                      class="<%= i === 0 ? 'thumbnail-active' : '' %>"
                    >
                <% }) %>
            </div>
        </div>

        <!-- RIGHT INFO -->
        <div class="right-info">

<div class="product-title"><%= product.productName %></div>



<%
  var defaultVariant = (sizeVariants && sizeVariants.length) ? sizeVariants[0] : null;
  var vPrice = defaultVariant ? Number(defaultVariant.price) : 0;
  var vDisc = (defaultVariant && defaultVariant.discountPrice !== null)
    ? Number(defaultVariant.discountPrice)
    : null;
%>

             <div class="product-price">
               <% if (vDisc !== null && vDisc > 0 && vDisc < vPrice) { %>
                 <span style="font-weight:700; font-size:20px;">Rs. <%= vDisc.toLocaleString('en-IN') %></span>
                 <span style="margin-left:10px; color:#777; text-decoration:line-through;">Rs. <%= vPrice.toLocaleString('en-IN') %></span>
                 <% var pcent = Math.round(((vPrice - vDisc) / vPrice) * 100); %>
                 <span style="margin-left:12px; background:#4d4c4c; padding:4px 8px; border-radius:4px;">-<%= pcent %>%</span>
               <% } else { %>
                 <span style="font-weight:700; font-size:20px;">Rs. <%= vPrice.toLocaleString('en-IN') %></span>
               <% } %>
             </div>

            <div class="mrp-text">MRP inclusive of all taxes</div>

  <% if (variants && variants.length) { %>
  <div class="color-text">
    COLOUR: <%= variants[0].color %>
  </div>
<% } %>
<% if (subcategory && subcategory.fitName) { %>
  <div class="subcat-text" style="margin-top:6px;font-size:14px;">
    <%= subcategory.fitName %>
  </div>
<% } %>

            <!-- SIZE SELECTOR -->
            <div class="size-box-wrap">
                <h4>SELECT A SIZE</h4>

                <div class="size-btns">
                    <% sizeVariants.forEach(function(s) { %>
<div 
  class="size-option <%= s.stock <= 0 ? 'disabled' : '' %>"
  onclick="selectSize(this, '<%= s.size %>', <%= s.stock %>, '<%= s._id %>')">
  <%= s.size %>
</div>

                    <% }) %>
                </div>
            </div>
            <div id="stockMessage"
     style="margin-top:10px;font-size:13px;color:#c00;display:none;">
</div>
 <input type="hidden" id="selectedVariantId" value="">

<% if (isUnavailable) { %>
  <div class="unavailable-box" style="color:rgb(143, 53, 53)">
    <h2>This product is currently unavailable</h2>
    <p style="color: #797979;">
      It may have been removed or is out of stock.<br>
      Explore similar products you might like.
    </p>
  </div>
<% } %>
            <!-- ADD TO BAG -->
<div style="display:flex; align-items:center; gap:14px; margin-top:25px;">
 <div
  class="add-btn <%= isUnavailable ? 'disabled-action' : '' %>"
  onclick="addToCart()"
>
  ADD TO BAG
</div>


<div
  onclick="toggleWishlist()"
  class="<%= isUnavailable ? 'disabled-action' : '' %>"
  style="cursor:pointer;display:flex;align-items:center;margin-top:21px;"
  title="Wishlist"
>

  <svg
    id="wishlistIcon"
    xmlns="http://www.w3.org/2000/svg"
    width="26"
    height="26"
    viewBox="0 0 24 24"
    fill="none"
    stroke="#fff"
    stroke-width="1.5"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <path d="M20.8 4.6c-1.8-1.8-4.7-1.8-6.5 0L12 6.9l-2.3-2.3c-1.8-1.8-4.7-1.8-6.5 0-1.8 1.8-1.8 4.7 0 6.5l8.8 8.8 8.8-8.8c1.8-1.8 1.8-4.7 0-6.5z"/>
  </svg>
</div>


</div>


        </div>

    </div>

    <!-- DESCRIPTION -->
  <div class="desc-section">
  <div class="desc-title">DESCRIPTION & FIT</div>

  <div
    class="desc-text"
    id="productDesc"
    data-full="<%- product.description %>"
  ></div>

  <button
    id="readMoreBtn"
    style="margin-top:14px;background:none;border:none;font-size: 12px ;color:white;font-weight: normal;cursor:pointer;display:none; text-decoration: underline;"
  >
    READ MORE
  </button>
</div>


    <!-- RECOMMENDATIONS -->
    <div class="recommend-title" >You May Also Like</div>

<div class="recommend-grid">
    <% recommendations.forEach(function(r) { %>
        <div onclick="window.location.href='/product/<%= r._id %>'" style="cursor:pointer;">
            <img src="<%= imageUrl(r.images[0]) %>">
            <div style="color: white; text-decoration:none; margin-top:6px;">
                <%= r.productName %>
            </div>
<strong style="color: #8b8b8b ">
  Rs. <%= (typeof r.finalPrice === 'number' ? r.finalPrice : 0).toLocaleString('en-IN') %>
</strong>


        </div>
    <% }) %>
</div>


</div>
<%- include('../partials/user/footer') %>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
function changeImage(el) {
    document.getElementById("mainImg").src = el.src;

    document.querySelectorAll(".thumbnail-grid img")
        .forEach(img => img.classList.remove("thumbnail-active"));

    el.classList.add("thumbnail-active");
}

function selectSize(el, size, stock, variantId) {
    var msg = document.getElementById('stockMessage');
    var selectedInput = document.getElementById('selectedVariantId');

    
    if (stock <= 0) {
        msg.innerText = 'Out of stock';
        msg.style.display = 'block';
        selectedInput.value = '';
        return;
    }

    // ✅ IN STOCK → clear message
    msg.innerText = '';
    msg.style.display = 'none';

    document.querySelectorAll(".size-option").forEach(b => b.classList.remove("active"));
    el.classList.add("active");

     selectedInput.value = variantId;

    // find the variant object for this size from a data structure rendered into the page
    var variantsData = <%- JSON.stringify(sizeVariants || []) %>;

    // find first variant matching size
    var found = null;
    for (var i = 0; i < variantsData.length; i++) {
      if (variantsData[i].size === size) { found = variantsData[i]; break; }
    }
    if (!found) return;

    var priceEl = document.querySelector('.product-price');
    var vPrice = Number(found.price || 0);
    var vDisc = (typeof found.discountPrice !== 'undefined' && found.discountPrice !== null) ? Number(found.discountPrice) : null;

    if (vDisc !== null && vDisc > 0 && vDisc < vPrice) {
      var pct = Math.round(((vPrice - vDisc) / vPrice) * 100);
      priceEl.innerHTML = '<span style="font-weight:700; font-size:20px;">Rs. ' + vDisc.toLocaleString('en-IN') + '</span>' +
                          '<span style="margin-left:10px; color:#777; text-decoration:line-through;">Rs. ' + vPrice.toLocaleString('en-IN') + '</span>' +
                          '<span style="margin-left:12px; background:#4d4c4c; padding:4px 8px; border-radius:4px;">-' + pct + '%</span>';
    } else {
      priceEl.innerHTML = '<span style="font-weight:700; font-size:20px;">Rs. ' + vPrice.toLocaleString('en-IN') + '</span>';
    }
}

function addToCart() {
    if (!<%= isLoggedIn ? 'true' : 'false' %>) {
    Swal.fire({
      
      title: 'Login required',
      text: 'Please log in to add items to your cart',
      showCancelButton: true,
      confirmButtonText: 'Login',
      confirmButtonColor: '#484848',
      cancelButtonText: 'Cancel'
    }).then(result => {
      if (result.isConfirmed) {
        window.location.href = '/login';
      }
    });
    return;
  }
  
   if (<%= isUnavailable ? 'true' : 'false' %>) return;
  const variantId = document.getElementById('selectedVariantId').value;
  const msg = document.getElementById('stockMessage');

 
  if (!variantId) {
    msg.innerText = 'Please select a size';
    msg.style.display = 'block';
    return;
  }

  msg.innerText = '';
  msg.style.display = 'none';

  fetch('/cart/add', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({ variantId })
  })
    .then(async res => {
      const data = await res.json();
      if (!res.ok || !data.success) {
        throw new Error(data.message || 'Failed to add to cart');
      }
      return data;
    })
    .then(() => {
  Swal.fire({
    icon: 'success',
    title: 'Added to cart',
    showCancelButton: true,
    confirmButtonText: 'Go to Cart',
    cancelButtonText: 'Keep Shopping'
  }).then(result => {
    if (result.isConfirmed) {
      window.location.href = '/cart';
    }
  });
})
.catch(err => {
      // Error handling from backend
      msg.innerText = err.message || 'Something went wrong';
      msg.style.display = 'block';
    });
}
</script>
<script>
  window.history.replaceState(null, null, window.location.href);
</script>
<script>
  window.addEventListener('pageshow', function (event) {
    if (event.persisted) {
      window.location.reload();
    }
  });
</script>

<script>
let isWishlisted = <%= isInWishlist ? 'true' : 'false' %>;
const productId = "<%= product._id %>";

function updateHeart(active) {
  const icon = document.getElementById('wishlistIcon');

  if (active) {
    icon.setAttribute('fill', '#d14b4b');
    icon.setAttribute('stroke', '#d14b4b');
    icon.setAttribute('stroke-width', active ? '2' : '1.5');
  } else {
    icon.setAttribute('fill', 'none');
    icon.setAttribute('stroke', 'rgba(255,255,255,0.6)');
  }

  isWishlisted = active;
}

function toggleWishlist() {

    if (!<%= isLoggedIn ? 'true' : 'false' %>) {
    Swal.fire({
      title: 'Login required',
      text: 'Please log in to use wishlist',
      showCancelButton: true,
      confirmButtonText: 'Login',
      confirmButtonColor: '#484848',
      cancelButtonText: 'Cancel'
    }).then(result => {
      if (result.isConfirmed) {
        window.location.href = '/login';
      }
    });
    return;
  }
  if (<%= isUnavailable ? 'true' : 'false' %>) return;

const url = isWishlisted ? '/wishlist/remove' : '/wishlist/add';
const method = isWishlisted ? 'DELETE' : 'POST';

fetch(url, {
  method,
  headers: { 'Content-Type': 'application/json' },
  body: JSON.stringify({ productId })
})

  .then(res => res.json())
  .then(data => {
    if (!data.success && !isWishlisted) return;

    updateHeart(!isWishlisted);

    Swal.fire({
      icon: 'success',
      title: isWishlisted ? 'Added to wishlist' : 'Removed from wishlist',
      timer: 1200,
      showConfirmButton: false
    });
  })
  .catch(() => {
    Swal.fire({ icon:'error', title:'Something went wrong' });
  });
}

document.addEventListener('DOMContentLoaded', () => {
  updateHeart(isWishlisted);
});

</script>
<script>
  (function () {
    const LIMIT = 400;
    const descEl = document.getElementById('productDesc');
    const btn = document.getElementById('readMoreBtn');

    if (!descEl) return;

    const fullText = descEl.dataset.full || '';
    if (fullText.length <= LIMIT) {
      descEl.textContent = fullText;
      return;
    }

    let expanded = false;
    const shortText = fullText.slice(0, LIMIT) + '...';

    descEl.textContent = shortText;
    btn.style.display = 'inline';

    btn.addEventListener('click', () => {
      expanded = !expanded;
      descEl.textContent = expanded ? fullText : shortText;
      btn.textContent = expanded ? 'READ LESS' : 'READ MORE';
    });
  })();
</script>

</body>
</html>
