<!DOCTYPE html>
<html>
<head>
  <title>Reset Password</title>

  <style>
    * {
      box-sizing: border-box;
      font-family: Arial, sans-serif;
    }

    body {
      margin: 0;
      padding: 0;
      background: #0a0e11;
      color: white;
    }

    .reset-wrapper {
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: calc(100vh - 120px);
      padding: 60px 20px;
    }

    .reset-main {
      width: 100%;
      max-width: 520px;
    }

    /* ===== BREADCRUMBS ===== */
    .breadcrumbs {
      margin-bottom: 18px;
      font-size: 14px;
      color: rgba(255,255,255,0.65);
      display: flex;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
    }

    .breadcrumbs a {
      color: rgba(255,255,255,0.75);
      text-decoration: none;
      transition: 0.3s;
    }

    .breadcrumbs a:hover {
      color: white;
    }

    /* ===== GLASS CARD ===== */
    .card {
      width: 100%;
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 16px;
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      box-shadow: 0 10px 30px rgba(0,0,0,0.35);
      padding: 45px 40px;
    }

    .card h2 {
      text-align: center;
      margin-bottom: 28px;
      font-size: 28px;
      letter-spacing: 1px;
      color: white;
    }

    input,
    button {
      width: 100%;
      padding: 14px 16px;
      margin-top: 16px;
      border-radius: 8px;
      font-size: 14px;
    }

    input {
      border: 1px solid rgba(255,255,255,0.08);
      background: rgba(255,255,255,0.04);
      color: white;
      outline: none;
    }

    input::placeholder {
      color: rgba(255,255,255,0.45);
    }

    input:focus {
      border-color: rgba(255,255,255,0.18);
      background: rgba(255,255,255,0.06);
    }

    button {
      background: rgba(255,255,255,0.04);
      color: white;
      border: 1px solid rgba(255,255,255,0.08);
      cursor: pointer;
      transition: 0.3s ease;
    }

    button:hover {
      background: rgba(255,255,255,0.08);
      transform: translateY(-1px);
    }
  </style>
</head>
<body>

<%-include('../partials/user/loggedinHeader')%>

<div class="reset-wrapper">
  <div class="reset-main">

    <!-- ===== BREADCRUMBS ===== -->
    <div class="breadcrumbs" id="breadcrumbs">
      <a href="/profile">Profile</a>
      <span>›</span>
      <span>Reset Password</span>
    </div>

    <div class="card">
      <h2>Set New Password</h2>

      <form method="POST" action="/profile/forgot-password/reset">
        <input type="password" name="newPassword" placeholder="New password" required />
        <input type="password" name="confirmPassword" placeholder="Confirm password" required />
        <button type="submit">Update Password</button>
      </form>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<% if (typeof message !== 'undefined' && message) { %>
<script>
  Swal.fire({
    icon: 'error',
    text: "<%= message %>",
    confirmButtonColor: '#4a4745'
  });
</script>
<% } %>

<% if (typeof success !== 'undefined' && success) { %>
<script>
  Swal.fire({
    icon: 'success',
    title: 'Password Updated',
    text: 'Your password has been updated successfully',
    confirmButtonColor: '#4a4745'
  }).then(() => {
    window.location.href = '/profile';
  });
</script>
<% } %>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const breadcrumb = document.getElementById("breadcrumbs");
    const referrer = document.referrer;

    if (referrer.includes("/profile/forgot-password/verify")) {
      breadcrumb.innerHTML = `
        <a href="/profile">Profile</a>
        <span>›</span>
        <a href="/profile/change-password">Change Password</a>
        <span>›</span>
        <a href="/profile/forgot-password">Verify Email</a>
        <span>›</span>
        <a href="/profile/forgot-password/verify">Verify OTP</a>
        <span>›</span>
        <span>Reset Password</span>
      `;
    }
  });
</script>

<%- include('../partials/user/footer') %>
</body>
</html>