<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Change Password</title>

<style>
  * {
    box-sizing: border-box;
    font-family: Arial, sans-serif;
  }

  html, body {
    min-height: 100vh;
  }

  body {
    margin: 0;
    background: #0a0e11;
    color: white;
    display: flex;
    flex-direction: column;
  }

  /* ===== PAGE LAYOUT ===== */
  .profile-page {
    flex: 1 0 auto;
    display: flex;
    width: 100%;
  }

  .profile-wrapper {
    display: flex;
    width: 100%;
    margin: 110px auto 0;
    padding: 40px 60px;
    gap: 40px;
    align-items: flex-start;
  }

  .profile-main {
    flex: 1;
    min-width: 0;
  }

  /* ===== PASSWORD CARD ===== */
  .password-card {
    flex: 1;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px;
    padding: 45px 40px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.35);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .password-title {
    text-align: center;
    font-size: 28px;
    letter-spacing: 2px;
    margin-bottom: 45px;
    color: white;
  }

  /* ===== FORM ===== */
  .password-form {
    max-width: 520px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 22px;
  }

  .password-form label {
    font-size: 14px;
    color: rgba(255,255,255,0.9);
    margin-bottom: 6px;
    display: block;
  }

  .password-form input {
    width: 100%;
    padding: 14px 16px;
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.08);
    background: rgba(255,255,255,0.04);
    color: white;
    font-size: 14px;
    outline: none;
    transition: 0.3s ease;
  }

  .password-form input:focus {
    border-color: rgba(255,255,255,0.2);
    background: rgba(255,255,255,0.06);
  }

  .update-btn {
    margin-top: 25px;
    align-self: center;
    background: rgba(255,255,255,0.04);
    color: white;
    border: 1px solid rgba(255,255,255,0.08);
    padding: 12px 30px;
    border-radius: 8px;
    cursor: pointer;
    font-size: 14px;
    transition: 0.3s ease;
  }

  .update-btn:hover {
    background: rgba(255,255,255,0.08);
    transform: translateY(-1px);
  }

  a {
    color: rgba(255,255,255,0.75) !important;
    text-decoration: none;
  }

  a:hover {
    color: white !important;
  }

  .breadcrumbs {
    margin-bottom: 25px;
    font-size: 14px;
    color: rgba(255,255,255,0.65);
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .breadcrumbs a {
    color: rgba(255,255,255,0.75);
    text-decoration: none;
    transition: 0.3s;
  }

  .breadcrumbs a:hover {
    color: white;
  }

  /* ===== TABLET ===== */
  @media (max-width: 992px) {
    .profile-wrapper {
      padding: 20px;
      margin-top: 100px;
    }

    .profile-wrapper > .sidebar {
      display: none;
    }

    .profile-main {
      margin-left: 80px;
      margin-right: 80px;
    }

    .password-card {
      width: 100%;
      padding: 24px;
    }
  }

  /* ===== MOBILE / SMALL TABLET ===== */
  @media (max-width: 768px) {
    .profile-wrapper {
      padding: 16px;
      gap: 20px;
    }

    .profile-main {
      margin-left: 0;
      margin-right: 0;
    }

    .password-card {
      padding: 20px;
    }

    .password-form {
      max-width: 100%;
    }

    .update-btn {
      width: 100%;
    }
  }

  /* ===== MOBILE ===== */
  @media (max-width: 480px) {
    .profile-wrapper {
      padding: 12px;
      margin-top: 90px;
    }

    .password-card {
      padding: 16px;
      border-radius: 12px;
    }

    .password-title {
      font-size: 22px;
      margin-bottom: 24px;
    }
  }
</style>
</head>

<body>
   <%- include('../partials/user/loggedinHeader') %>
<main class="profile-page">
<div class="profile-wrapper">

  <!-- ===== SIDEBAR ===== -->
<%- include('../partials/user/profileSidebar') %>
  <!-- ===== CHANGE PASSWORD CARD ===== -->
   <div class="profile-main">
     <div class="breadcrumbs" id="breadcrumbs">
    <a href="/profile">Profile</a>
    <span>›</span>
    <span>Change Password</span>
  </div>
  <section class="password-card">


    <h2 class="password-title">CHANGE PASSWORD</h2>

    <form method="POST" action="/profile/change-password" class="password-form">

      <div>
        <label>Enter Current Password</label>
        <input type="password" name="currentPassword" />
      </div>

      <div>
        <label>Enter New Password</label>
        <input type="password" name="newPassword" />
      </div>

      <div>
        <label>Confirm New Password</label>
        <input type="password" name="confirmPassword" />
      </div>
       <div style="text-align:center;margin-top:10px;">
  <a href="/profile/forgot-password" style="font-size:13px;color:#4a4745;">
    Forgot password / Signed-in with google ?
  </a>
</div>

      <button type="submit" class="update-btn">
        Update Password
      </button>

    </form>

  </section>
</div>
</div>
</main>
<%- include('../partials/user/footer') %>
</body>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<% if (typeof message !== 'undefined' && message) { %>
<script>
  Swal.fire({
    icon: 'error',
    text: "<%= message %>",
    confirmButtonColor: '#4a4745'
  });
</script>
<% } %>

<% if (typeof success !== 'undefined' && success) { %>
<script>
  Swal.fire({
    icon: 'success',
    title: 'Password Updated',
    text: 'Your password has been changed successfully',
    confirmButtonColor: '#4a4745'
  }).then(() => {
    window.location.href = '/profile';
  });
</script>
<% } %>

<% if (typeof fatalError !== 'undefined' && fatalError) { %>
<script>
  Swal.fire({
    icon: 'error',
    title: 'Error',
    text: 'Error occurred while changing password',
    showCancelButton: true,
    confirmButtonText: 'Go to Profile',
    confirmButtonColor: '#4a4745'
  }).then(() => {
    window.location.href = '/profile';
  });
</script>
<% } %>
<script>
  document.addEventListener("DOMContentLoaded", function () {
    const breadcrumb = document.getElementById("breadcrumbs");
    const referrer = document.referrer;

    if (referrer.includes("/profile/edit")) {
      breadcrumb.innerHTML = `
        <a href="/profile">Profile</a>
        <span>›</span>
        <a href="/profile/edit">Edit Profile</a>
        <span>›</span>
        <span>Change Password</span>
      `;
    } else {
      breadcrumb.innerHTML = `
        <a href="/profile">Profile</a>
        <span>›</span>
        <span>Change Password</span>
      `;
    }
  });
</script>
</html>
