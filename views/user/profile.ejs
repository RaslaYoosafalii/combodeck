<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>User Profile</title>

  <style>
    * {
      box-sizing: border-box;
      font-family: "Arial", sans-serif;
    }

html, body {
  min-height: 100vh;
}

body {
  margin: 0;
  background: #0a0e11;
  color: white;
  display: flex;
  flex-direction: column;
}
    

    /* ===== LAYOUT ===== */
.profile-wrapper {
  display: flex;
  width: 100%;
  margin: 110px auto 0;
  padding: 40px 60px;
  gap: 40px;
  align-items: flex-start;
}

  /* ===== SIDEBAR ===== */
  .sidebar {
  width: 260px;
  border: 1px solid rgba(255,255,255,0.08);
  background: rgba(255,255,255,0.03);
  border-radius: 16px;
  backdrop-filter: blur(10px);
  overflow: hidden;
  }

    .sidebar-header {
  background: rgba(255,255,255,0.04);
  color: white;
  padding: 18px;
  display: flex;
  align-items: center;
  gap: 12px;
  border-bottom: 1px solid rgba(255,255,255,0.08);
    }

    .sidebar-header .avatar-small {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: #d9d9d9;
    }

    .sidebar-menu {
      list-style: none;
      margin: 0;
      padding: 0;
    }

    .sidebar-menu li {
        border-top: 1px solid rgba(255,255,255,0.08);

    }

    .sidebar-menu a {
    display: flex;
  align-items: center;
  gap: 12px;
  padding: 14px 18px;
  color: white;
  text-decoration: none;
  font-size: 14px;
    }

    .sidebar-menu a:hover,
    .sidebar-menu .active {
      background-color: #868686;
      font-weight: 600;
    }

    /* ===== MAIN PROFILE CARD ===== */
    .profile-card {
 flex: 1;
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 16px;
  padding: 40px;
  box-shadow: 0 10px 30px rgba(0,0,0,0.35);
  backdrop-filter: blur(10px);
  position: relative;
  min-width: 0;
    }

    .profile-title {
      text-align: center;
      font-size: 28px;
      letter-spacing: 2px;
      margin-bottom: 40px;
    }

    .edit-profile-btn {
      position: absolute;
      top: 40px;
      right: 40px;
      background: rgb(90, 85, 83);
      color: #fff;
      border: none;
      padding: 8px 14px;
      border-radius: 6px;
      font-size: 13px;
      cursor: pointer;

        position: absolute;
  top: 40px;
  right: 40px;
  background: rgba(255,255,255,0.04);
  color: white;
  border: 1px solid rgba(255,255,255,0.08);
  padding: 8px 14px;
  border-radius: 6px;
  font-size: 13px;
  cursor: pointer;
    }

    /* ===== PROFILE CONTENT ===== */
    .profile-content {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 25px;
    }

    .avatar-large {

  width: 120px;
  height: 120px;
  border-radius: 50%;
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.08);
    }

    .field-group {
      width: 100%;
      max-width: 420px;
      display: flex;
      align-items: center;
      gap: 20px;
    }

    .field-group label {
      width: 90px;
      font-weight: 600;
      text-align: right;
    }

    .field-value {
      flex: 1;
      background: #d9d9d9;
      padding: 10px 14px;
      border-radius: 6px;
      font-size: 14px;

  flex: 1;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.08);
  color: white;
  padding: 10px 14px;
  border-radius: 6px;
  font-size: 14px;
  word-break: break-word;
    }

    .change-password-btn {
      margin-top: 30px;
      background: #5a5553;
      color: #fff;
      border: none;
      padding: 10px 22px;
      border-radius: 6px;
      cursor: pointer;
      font-size: 14px;

        margin-top: 30px;
  background: rgba(255,255,255,0.04);
  color: white;
  border: 1px solid rgba(255,255,255,0.08);
  padding: 10px 22px;
  border-radius: 6px;
  cursor: pointer;
  font-size: 14px;
    }
.profile-page {
  flex: 1 0 auto;
  display: flex;
  width: 100%;
}
 

@media (max-width: 992px) {
  .profile-wrapper {
    padding: 20px;
    margin-top: 100px;
  }

  .profile-wrapper > .sidebar {
    display: none;
  }

  .profile-card {
    width: 100%;
    padding: 24px;
    margin-left: 80px;
    margin-right: 80px;
  }
}

@media (max-width: 768px) {
  .profile-wrapper {
    padding: 16px;
    gap: 20px;
  }

  .profile-card {
    padding: 20px;
  }

  .edit-profile-btn {
    position: static;
    display: block;
    margin: 0 auto 25px;
  }

  .field-group {
    max-width: 100%;
    flex-direction: column;
    align-items: stretch;
    gap: 8px;
  }

  .field-group label {
    width: 100%;
    text-align: left;
  }
}

@media (max-width: 480px) {
  .profile-wrapper {
    padding: 12px;
    margin-top: 90px;
  }

  .profile-card {
    padding: 16px;
    border-radius: 12px;
  }

  .profile-title {
    font-size: 22px;
    margin-bottom: 24px;
  }

  .avatar-large {
    width: 90px;
    height: 90px;
  }

  .change-password-btn,
  .edit-profile-btn {
    width: 100%;
  }
}
  
  </style>
</head>

<body>
  <%- include('../partials/user/loggedinHeader') %>
  <main class="profile-page">
    <div class="profile-wrapper">

    <!-- ===== SIDEBAR ===== -->
<%- include('../partials/user/profileSidebar') %>

    <!-- ===== PROFILE CARD ===== -->
    <section class="profile-card">
      <h2 class="profile-title">PROFILE</h2>

      <button class="edit-profile-btn" onclick="location.href='/profile/edit'">
        ✎ edit profile
      </button>

      <div class="profile-content">
        <% if (user?.profileImage) { %>
  <img
    src="<%= user.profileImage %>"
    alt="Profile Image"
    class="avatar-large"
    style="object-fit: cover;"
  />
<% } else { %>
  <div class="avatar-large"></div>
<% } %>


        <div class="field-group">
          <label>Name:</label>
          <div class="field-value">
            <%= user?.name || '—' %>
          </div>
        </div>

        <div class="field-group">
          <label>Email:</label>
          <div class="field-value">
            <%= user?.email || '—' %>
          </div>
        </div>

        <div class="field-group">
          <label>Phone:</label>
          <div class="field-value">
            <%= user?.mobileNumber || '—' %>
          </div>
        </div>

        <button class="change-password-btn" onclick="location.href='/profile/change-password'">
          Change password
        </button>
      </div>
    </section>

    </div>
  </main>

  <%- include('../partials/user/footer') %>
</body>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<% if (typeof emailUpdated !== 'undefined' && emailUpdated) { %>
<script>
  Swal.fire({
    icon: 'success',
    title: 'Email Updated',
    text: 'Email verified and updated successfully',
    confirmButtonColor: '#4a4745'
  });
</script>
<% } %>
<% if (passwordChanged) { %>
<script>
  Swal.fire({
    icon: 'success',
    title: 'Password Updated',
    text: 'Your password has been changed securely',
    confirmButtonColor: '#4a4745'
  });
</script>
<% } %>

</html>
