/* RIGHT GLASS CARDS */

.info-cards{
position:absolute;
right:60px;
top:455px;
display:flex;
flex-direction:column;
gap:25px;
}

.card{
width:260px;
padding:22px;

background:rgba(0, 0, 0, 0.05);
border:1px solid rgba(255,255,255,0.1);
border-radius:16px;
backdrop-filter:blur(10px);
}
.card:hover{
opacity:1;
color: rgb(220, 173, 102);
}

.card h4{
font-size:13px;
letter-spacing:2px;
margin-bottom:10px;
}

.card p{
font-size:12px;
opacity:.7;
line-height:1.6;
}

/* LEFT TEXT */

.left-info{
position:absolute;
left:60px;
bottom:30px;
}

.left-info h2{
font-size:22px;
letter-spacing:3px;
line-height:1.5;
}

.arrow{
margin-top:18px;
width:42px;
height:42px;
border-radius:50%;
background:rgba(255,255,255,0.08);
display:flex;
align-items:center;
justify-content:center;
font-size:20px;
}

