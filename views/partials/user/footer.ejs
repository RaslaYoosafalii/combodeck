<style>
  /* Loader overlay */
#globalLoader {
  position: fixed;
  top:0; left:0;
  width:100vw; height:100vh;
  background: rgba(0,0,0,0.35);
  backdrop-filter: blur(8px);
  display:flex;
  justify-content:center;
  align-items:center;
  z-index:9999;
}
.ring {
  position: absolute;
  width: 160px;
  height: 160px;
  border-radius: 50%;
  border: 2px solid rgba(255,255,255,0.1);
  border-top: 2px solid rgba(255,255,255,0.6);
  animation: spin 1.2s linear infinite;
}

@keyframes spin {
  100% { transform: rotate(360deg); }
}
/* Logo container */
.logo-loader {
  width: 140px;
  height: 140px;
  display:flex;
  justify-content:center;
  align-items:center;
}

/* Logo animation */
.logo-loader img {
  width: 100%;
  height: auto;
  animation: 
    pulseGlow 2s ease-in-out infinite,
    slightRotate 4s linear infinite;
}

/* Glow + pulse */
@keyframes pulseGlow {
  0% {
    transform: scale(1);
    filter: drop-shadow(0 0 5px rgba(255,255,255,0.2));
    opacity: 0.8;
  }
  50% {
    transform: scale(1.08);
    filter: drop-shadow(0 0 25px rgba(255,255,255,0.6));
    opacity: 1;
  }
  100% {
    transform: scale(1);
    filter: drop-shadow(0 0 5px rgba(255,255,255,0.2));
    opacity: 0.8;
  }
}


</style>