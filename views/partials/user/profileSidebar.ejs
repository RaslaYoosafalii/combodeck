    
    <style>

  .sidebar {
    width: 260px;
    background: linear-gradient(
      135deg,
      rgba(255,255,255,0.08),
      rgba(255,255,255,0.02)
    );
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 18px;
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    overflow: hidden;
    box-shadow:
      0 8px 32px rgba(0,0,0,0.28),
      inset 0 1px 0 rgba(255,255,255,0.08);
  }

  .sidebar-header {
    background: rgba(255,255,255,0.04);
    color: white;
    padding: 18px;
    display: flex;
    align-items: center;
    gap: 12px;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    backdrop-filter: blur(12px);
  }

  .sidebar-header .avatar-small {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.12);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.08);
  }

  .sidebar-menu {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .sidebar-menu li {
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .sidebar-menu a {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 18px;
    color: rgba(255,255,255,0.88);
    text-decoration: none;
    font-size: 14px;
    transition: all 0.25s ease;
    background: transparent;
  }

  .sidebar-menu a:hover,
  .sidebar-menu a.active {
    background: rgba(255,255,255,0.06) !important;
    backdrop-filter: blur(8px) !important;
    font-weight: 600;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.04) !important;
  }

  .logout-btn:hover {
    color: #ff7b7b !important;
    background: rgba(255, 107, 107, 0.08) !important;
  }
</style>
</style>
    </style>
    <aside class="sidebar">
      <div class="sidebar-header">
         <% if (user?.profileImage) { %>
    <img
      src="<%= user.profileImage %>"
      alt="Profile Image"
      class="avatar-small"
      style="object-fit: cover;"
    />
  <% } else { %>
    <div class="avatar-small"></div>
  <% } %>
        <strong><%= user?.name || 'User' %></strong>
      </div>

      <ul class="sidebar-menu">
        <li><a href="/profile">Profile</a></li>
        <li><a href="/profile/referral">Referral Code</a></li>
        <li><a href="/orders">My Orders</a></li>
        <li><a href="/wallet">Wallet</a></li>
        <li><a href="/address">Address</a></li>
        <li><a href="/logout" class="btn logout-btn">Logout</a></li>
      </ul>
    </aside>
    <script>
  document.addEventListener("DOMContentLoaded", function () {

    const currentPath = window.location.pathname;

    const sidebarLinks = document.querySelectorAll(".sidebar-menu a[href]");

    sidebarLinks.forEach(link => {

      const linkPath = link.getAttribute("href");

      if (!linkPath || linkPath === "/logout") return;

      // Exact match
      if (currentPath === linkPath) {
        link.classList.add("active");
      }

      // Handle nested routes
      else if (currentPath.startsWith(linkPath) && linkPath !== "/profile") {
        link.classList.add("active");
      }

      // Special case for profile root
      else if (linkPath === "/profile" && currentPath === "/profile") {
        link.classList.add("active");
      }

    });

  });
</script>

 

