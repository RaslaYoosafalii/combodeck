
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
<style>
.navbar{
display:flex;
justify-content:space-between;
align-items:center;
padding:20px 60px;
background:transparent;
position:fixed;
top:0;
left:0;
width:100%;
backdrop-filter:blur(1px);
z-index:1000;
}

.logo a{
font-family:'Orbitron',sans-serif;
font-size:34px;
letter-spacing:3px;
color:white;
text-decoration: none;
}

.bottom-nav{
margin-left:auto;
margin-right:20px;
}
.nav-right-group{
display:flex;
align-items:center;
gap:10px;
}
.bottom-nav ul{
display:flex;
gap:60px;
list-style:none;

}

.bottom-nav a{
text-decoration:none;
color:white;
font-size:15px;
opacity:.85;
transition:.3s;
font-family: 'Arial', sans-serif;
}

.bottom-nav a:hover{
opacity:1;
color: rgb(220, 173, 102);
}

.tech-pill{
border:1px solid rgba(255,255,255,0.2);
padding:12px 22px;
border-radius:30px;
font-size:13px;
font-family: 'Arial', sans-serif;
letter-spacing:2px;
background:rgba(255,255,255,0.05);
color:white;
}

.tech-pill:hover{
  color: rgb(220, 173, 102);
}

.menu-toggle{
display:none;
font-size:26px;
color:white;
cursor:pointer;
z-index:1200;
flex-shrink:0;
}

.mobile-menu{
position:fixed;
top:0;
right:-320px;
width:280px;
height:100vh;
background:rgba(15,15,15,0.75);
backdrop-filter:blur(18px);
-webkit-backdrop-filter:blur(18px);
border-left:1px solid rgba(255,255,255,0.08);
padding:100px 30px 30px;
transition:right 0.35s ease;
z-index:1100;
box-shadow:-10px 0 30px rgba(0,0,0,0.4);
}

.mobile-menu.active{
right:0;
}

.mobile-menu ul{
list-style:none;
padding:0;
margin:0;
display:flex;
flex-direction:column;
gap:25px;
}

.mobile-menu a{
color:white;
text-decoration:none;
font-size:18px;
font-family:'Arial', sans-serif;
opacity:.9;
transition:.3s;
}

.mobile-menu a:hover{
color:rgb(220, 173, 102);
}
.profile-toggle{
display:none;
width:22px;
height:20px;

align-items:center;
justify-content:center;
padding-top: 5px;
cursor:pointer;
margin-left:10px; /* fixed consistent gap */
z-index:1200;
flex-shrink:0;
}
.profile-toggle:hover{
border-radius: 5px;
border:1px solid rgba(255,255,255,0.05);
color:rgb(220, 173, 102);
}
.profile-mobile-panel{
position:fixed;
top:0;
right:-320px;
width:280px;
height:100vh;
background:rgba(15,15,15,0.75);
backdrop-filter:blur(18px);
-webkit-backdrop-filter:blur(18px);
border-left:1px solid rgba(255,255,255,0.08);
padding:100px 20px 20px;
transition:right 0.35s ease;
z-index:1150;
overflow-y:auto;
}

.profile-mobile-panel.active{
right:0;
}
@media(min-width:1300px){
  .profile-mobile-panel{
    display:none !important;
  }

  .profile-toggle{
    display:none !important;
  }
}
@media(max-width:1300px){
.navbar{
padding:18px 20px;
}

.bottom-nav{
display:none;
}

.logo a{
font-size:24px;
letter-spacing:2px;
}

.tech-pill{
padding:10px 16px;
font-size:11px;
letter-spacing:1px;
margin-left:auto;
}
.profile-toggle{
display:flex;
}
.menu-toggle{
display:block;
}
}

@media(max-width:480px){
.logo a{
font-size:22px;
}

.tech-pill{
font-size:10px;
padding:8px 12px;
}
}
.mobile-tech-pill{
display:none;
border:1px solid rgba(255,255,255,0.2);
padding:12px 18px;
border-radius:30px;
font-size:12px;
letter-spacing:2px;
background:rgba(255,255,255,0.05);
color:white;
font-family:'Arial', sans-serif;
margin-bottom:35px;
width:fit-content;
}

@media(max-width:600px){
.tech-pill{
display:none;
}

.mobile-tech-pill{
display:block;
}

.navbar{
padding:16px 14px;
}


}
.tech-pill{
    text-decoration:none;
    display:flex;
    align-items:center;
    justify-content:center;
}
.mobile-tech-pill a{
    text-decoration:none;
    color:white;
}

.mobile-tech-pill a:hover{
    color:rgb(220,173,102);
}
.tech-pill{
    transition:.3s ease;
}

.tech-pill:hover{
    color:rgb(220,173,102);
    border-color:rgba(220,173,102,.3);
    background:rgba(220,173,102,.08);
}
</style>

