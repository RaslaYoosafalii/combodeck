</div>

<nav class="bottom-nav">
<ul>
        <li><a href="/">Home</a></li>
        <li><a href="#">About</a></li>
        <li><a href="/products">Shop</a></li>
        <li><a href="/wishlist">Wishlist</a></li>
        <li><a href="/cart">Your Cart</a></li>
        <li><a href="/profile"   style="margin-right:15px;">Profile</a></li>
